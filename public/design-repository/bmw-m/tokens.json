      "link": {
        "fontFamily": "\"BMWTypeNextLatin\", system-ui, sans-serif",
        "fontSize": "14px",
        "fontWeight": "700",
        "lineHeight": "1.3",
        "backgroundColor": "transparent",
        "color": "#ffffff",
        "letterSpacing": "1.5px"
      },
      "linkActive": {
        "fontFamily": "\"BMWTypeNextLatin\", system-ui, sans-serif",
        "fontSize": "14px",
        "fontWeight": "700",
        "lineHeight": "1.3",
        "backgroundColor": "transparent",
        "color": "#ffffff",
        "letterSpacing": "1.5px"
      }
    },
    "tabActive": {
      "backgroundColor": "transparent",
      "color": "#ffffff",
      "padding": "12px 0",
      "fontFamily": "\"BMWTypeNextLatin\", system-ui, sans-serif",
