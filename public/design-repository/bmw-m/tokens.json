      "fontWeight": "700",
      "lineHeight": "1.3",
      "letterSpacing": "1.5px",
      "borderRadius": "6px",
      "cursor": "default",
      "display": "inline-block"
    },
    "tabInactive": {
      "backgroundColor": "transparent",
      "color": "#bbbbbb",
      "padding": "12px 0",
      "fontFamily": "\"BMWTypeNextLatin\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "700",
      "lineHeight": "1.3",
      "letterSpacing": "1.5px",
      "border": "1px solid #3c3c3c",
      "borderRadius": "6px",
      "cursor": "default",
      "display": "inline-block"
    },
    "alert": {
      "backgroundColor": "#ffffff",
      "color": "#ffffff",
      "padding": "12px 16px",
      "borderRadius": "6px",
      "border": "1px solid #3c3c3c",
      "borderLeft": "3px solid #ffffff",
      "fontFamily": "\"BMWTypeNextLatin Light\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "300",
      "lineHeight": "1.5"
    },
    "code": {
      "backgroundColor": "#ffffff",
      "color": "#f4f1ea",
      "padding": "14px 16px",
      "borderRadius": "6px",
      "fontFamily": "\"DM Mono\", ui-monospace, monospace",
      "fontSize": "13px",
      "lineHeight": "1.5",
