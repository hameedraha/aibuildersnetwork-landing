  "rounded": {
    "none": "0px",
    "xs": "2px",
    "sm": "4px",
    "md": "6px",
    "full": "9999px"
  },
  "fonts": [
    {
      "name": "BMWTypeNextLatin, sans-serif",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    },
    {
      "name": "BMWTypeNextLatin Light, BMWTypeNextLatin, sans-serif",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    },
    {
      "name": "BMWTypeNextLatin Light, sans-serif",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    }
