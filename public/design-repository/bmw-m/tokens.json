      "backgroundColor": "#000000",
      "color": "#ffffff",
      "padding": "16px 32px",
      "fontFamily": "\"BMWTypeNextLatin\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "700",
