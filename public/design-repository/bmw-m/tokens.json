      "overflowX": "auto"
    },
    "label": {
      "fontFamily": "\"BMWTypeNextLatin\", system-ui, sans-serif",
      "fontSize": "12px",
      "fontWeight": "400",
      "lineHeight": "1.4",
      "letterSpacing": "0.5px"
    },
    "accordion": {
      "backgroundColor": "#ffffff",
      "color": "#ffffff",
      "border": "1px solid #3c3c3c",
      "borderRadius": "6px",
      "summaryColor": "#ffffff",
      "summaryStyle": {
        "fontFamily": "\"BMWTypeNextLatin\", system-ui, sans-serif",
        "fontSize": "40px",
        "fontWeight": "700",
        "lineHeight": "1.1",
        "color": "#ffffff",
        "padding": "12px 16px"
      },
      "mutedColor": "#7e7e7e"
    }
