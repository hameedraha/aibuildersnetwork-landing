{
  "colors": {
    "primary": "#17171c",
    "cohere-black": "#000000",
    "ink": "#212121",
    "deep-green": "#003c33",
    "dark-navy": "#071829",
    "canvas": "#ffffff",
    "soft-stone": "#eeece7",
    "pale-green": "#edfce9",
    "pale-blue": "#f1f5ff",
    "hairline": "#d9d9dd",
    "border-light": "#e5e7eb",
    "card-border": "#f2f2f2",
    "muted": "#93939f",
    "slate": "#75758a",
    "body-muted": "#616161",
    "action-blue": "#1863dc",
    "focus-blue": "#4c6ee6",
    "coral": "#ff7759",
    "coral-soft": "#ffad9b",
    "form-focus": "#9b60aa",
    "on-primary": "#ffffff",
    "on-dark": "#ffffff",
    "error": "#b30000"
  },
  "primaryColors": {
    "primary": "#17171c",
    "on-primary": "#ffffff"
  },
  "typography": {
    "hero-display": {
      "fontFamily": "CohereText",
      "fontSize": "96px",
      "fontWeight": 400,
      "lineHeight": 1,
      "letterSpacing": "-1.92px"
    },
    "product-display": {
      "fontFamily": "CohereText",
      "fontSize": "72px",
      "fontWeight": 400,
      "lineHeight": 1,
      "letterSpacing": "-1.44px"
    },
    "section-display": {
      "fontFamily": "Unica77 Cohere Web",
      "fontSize": "60px",
      "fontWeight": 400,
      "lineHeight": 1,
      "letterSpacing": "-1.2px"
    },
    "section-heading": {
      "fontFamily": "Unica77 Cohere Web",
      "fontSize": "48px",
      "fontWeight": 400,
      "lineHeight": 1.2,
      "letterSpacing": "-0.48px"
    },
    "card-heading": {
      "fontFamily": "Unica77 Cohere Web",
      "fontSize": "32px",
      "fontWeight": 400,
      "lineHeight": 1.2,
      "letterSpacing": "-0.32px"
    },
    "feature-heading": {
      "fontFamily": "Unica77 Cohere Web",
      "fontSize": "24px",
      "fontWeight": 400,
      "lineHeight": 1.3,
      "letterSpacing": 0
    },
    "body-large": {
      "fontFamily": "Unica77 Cohere Web",
      "fontSize": "18px",
      "fontWeight": 400,
      "lineHeight": 1.4,
      "letterSpacing": 0
    },
    "body": {
      "fontFamily": "Unica77 Cohere Web",
      "fontSize": "16px",
      "fontWeight": 400,
      "lineHeight": 1.5,
      "letterSpacing": 0
    },
    "button": {
      "fontFamily": "Unica77 Cohere Web",
      "fontSize": "14px",
      "fontWeight": 500,
      "lineHeight": 1.71,
      "letterSpacing": 0
    },
    "caption": {
      "fontFamily": "Unica77 Cohere Web",
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": 1.4,
      "letterSpacing": 0
    },
    "mono-label": {
      "fontFamily": "CohereMono",
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": 1.4,
      "letterSpacing": "0.28px"
    },
    "micro": {
      "fontFamily": "Unica77 Cohere Web",
      "fontSize": "12px",
      "fontWeight": 400,
      "lineHeight": 1.4,
      "letterSpacing": 0
    }
  },
  "components": {
    "button-primary": {
      "backgroundColor": "{colors.primary}",
      "textColor": "{colors.on-primary}",
      "typography": "{typography.button}",
      "rounded": "{rounded.pill}",
      "padding": "12px 24px"
    },
    "button-secondary": {
      "backgroundColor": "transparent",
      "textColor": "{colors.ink}",
      "typography": "{typography.body}",
      "rounded": "{rounded.xs}",
      "padding": "8px 0"
    },
    "button-pill-outline": {
      "backgroundColor": "transparent",
      "textColor": "{colors.primary}",
      "typography": "{typography.button}",
      "rounded": "{rounded.xl}",
      "padding": "6px 12px"
    },
    "announcement-bar": {
      "backgroundColor": "{colors.cohere-black}",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.micro}",
      "height": "36px"
    },
    "hero-photo-card": {
      "backgroundColor": "{colors.canvas}",
      "rounded": "{rounded.lg}"
    },
    "agent-console-card": {
      "backgroundColor": "{colors.primary}",
      "textColor": "{colors.on-dark}",
      "rounded": "{rounded.sm}",
      "padding": "24px"
    },
    "trust-logo-strip": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.caption}"
    },
    "capability-card": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body}",
      "rounded": "{rounded.xs}",
      "padding": "24px"
    },
    "dark-feature-band": {
      "backgroundColor": "{colors.deep-green}",
      "textColor": "{colors.on-dark}",
      "rounded": "{rounded.lg}",
      "padding": "80px"
    },
    "product-card": {
      "backgroundColor": "{colors.soft-stone}",
      "textColor": "{colors.ink}",
      "rounded": "{rounded.sm}",
      "padding": "32px"
    },
    "blog-filter-chip": {
      "backgroundColor": "transparent",
      "textColor": "{colors.coral}",
      "typography": "{typography.card-heading}",
      "rounded": "{rounded.sm}",
      "padding": "8px 14px"
    },
    "research-table": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-large}"
    },
    "contact-form-card": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "rounded": "{rounded.lg}",
      "padding": "32px"
    },
    "footer-newsletter": {
      "backgroundColor": "{colors.primary}",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.micro}"
    }
  },
  "rounded": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "22px",
    "xl": "30px",
    "pill": "32px",
    "full": "9999px"
  },
  "fonts": [
    {
      "name": "CohereText",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    },
    {
      "name": "Unica77 Cohere Web",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    },
    {
      "name": "CohereMono",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    }
  ],
  "playground": {
    "canvas": "#ffffff",
    "ink": "#212121",
    "surface": "#ffffff",
    "hairline": "#d9d9dd",
    "muted": "#93939f",
    "radiusMd": "16px",
    "buttonPrimary": {
      "backgroundColor": "#17171c",
      "color": "#ffffff",
      "padding": "12px 24px",
      "borderRadius": "32px",
      "fontFamily": "\"Unica77 Cohere Web\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "500",
      "lineHeight": "1.71",
      "cursor": "default",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center"
    },
    "buttonSecondary": {
      "backgroundColor": "transparent",
      "color": "#212121",
      "padding": "8px 0",
      "borderRadius": "4px",
      "fontFamily": "\"Unica77 Cohere Web\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "cursor": "default",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center"
    },
    "body": {
      "fontFamily": "\"Unica77 Cohere Web\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5"
    },
    "headline": {},
    "card": {
      "backgroundColor": "#ffffff",
      "borderRadius": "22px",
      "color": "#212121",
      "padding": "24px",
      "border": "1px solid #d9d9dd",
      "fontFamily": "\"Unica77 Cohere Web\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5"
    },
    "input": {
      "backgroundColor": "#ffffff",
      "color": "#212121",
      "padding": "10px 14px",
      "borderRadius": "16px",
      "border": "1px solid #d9d9dd",
      "fontFamily": "\"Unica77 Cohere Web\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "width": "100%",
      "boxSizing": "border-box"
    },
    "badge": {
      "backgroundColor": "#17171c",
      "color": "#ffffff",
      "padding": "4px 10px",
      "borderRadius": "16px",
      "fontFamily": "\"Unica77 Cohere Web\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "display": "inline-block"
    },
    "link": {
      "color": "#17171c",
      "textDecoration": "underline",
      "textUnderlineOffset": "2px",
      "fontFamily": "\"Unica77 Cohere Web\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "cursor": "default"
    },
    "nav": {
      "bar": {
        "backgroundColor": "#ffffff",
        "color": "#212121",
        "border": "1px solid #d9d9dd",
        "borderRadius": "16px",
        "padding": "12px 16px",
        "display": "flex",
        "alignItems": "center",
        "gap": "20px",
        "flexWrap": "wrap"
      },
      "link": {
        "fontFamily": "\"Unica77 Cohere Web\", system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": "400",
        "lineHeight": "1.5",
        "color": "#212121"
      },
      "linkActive": {
        "fontFamily": "\"Unica77 Cohere Web\", system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": "400",
        "lineHeight": "1.5",
        "color": "#17171c"
      }
    },
    "tabActive": {
      "backgroundColor": "#17171c",
      "color": "#ffffff",
      "padding": "8px 14px",
      "borderRadius": "16px",
      "fontFamily": "\"Unica77 Cohere Web\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "cursor": "default",
      "display": "inline-block"
    },
    "tabInactive": {
      "backgroundColor": "#ffffff",
      "color": "#212121",
      "fontFamily": "\"Unica77 Cohere Web\", system-ui, sans-serif",
      "fontSize": "18px",
      "fontWeight": "400",
      "lineHeight": "1.4",
      "border": "1px solid #d9d9dd",
      "padding": "8px 14px",
      "borderRadius": "16px",
      "cursor": "default",
      "display": "inline-block"
    },
    "alert": {
      "backgroundColor": "#ffffff",
      "color": "#212121",
      "padding": "12px 16px",
      "borderRadius": "16px",
      "border": "1px solid #d9d9dd",
      "borderLeft": "3px solid #17171c",
      "fontFamily": "\"Unica77 Cohere Web\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5"
    },
    "code": {
      "backgroundColor": "#212121",
      "color": "#f4f1ea",
      "padding": "14px 16px",
      "borderRadius": "16px",
      "fontFamily": "\"DM Mono\", ui-monospace, monospace",
      "fontSize": "13px",
      "lineHeight": "1.5",
      "display": "block",
      "overflowX": "auto"
    },
    "label": {
      "fontFamily": "\"Unica77 Cohere Web\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "400",
      "lineHeight": "1.4"
    },
    "accordion": {
      "backgroundColor": "#ffffff",
      "color": "#212121",
      "border": "1px solid #d9d9dd",
      "borderRadius": "16px",
      "summaryColor": "#212121",
      "summaryStyle": {
        "fontFamily": "\"Unica77 Cohere Web\", system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": "400",
        "lineHeight": "1.5",
        "color": "#212121",
        "padding": "12px 16px"
      },
      "mutedColor": "#93939f"
    }
  }
}
