      "link": {
        "fontFamily": "\"IBM Plex Sans\", system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": "400",
        "lineHeight": "1.5",
        "letterSpacing": "0.16px",
        "color": "#161616"
