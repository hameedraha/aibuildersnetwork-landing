      "fontWeight": "400",
      "lineHeight": "1.29",
      "letterSpacing": "0.16px",
      "borderRadius": "6px",
      "cursor": "default",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center"
