      "fontSize": "14px",
      "fontWeight": "400",
      "lineHeight": "1.29",
      "letterSpacing": "0.16px",
      "border": "1px solid #e0e0e0",
      "borderRadius": "6px",
      "cursor": "default",
      "display": "inline-block"
