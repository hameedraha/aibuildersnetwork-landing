  "rounded": {
    "xs": "4px",
    "sm": "6px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "xxl": "20px",
    "xxxl": "24px",
    "hero": "32px",
    "full": "9999px"
  },
  "fonts": [
    {
      "name": "DM Sans",
      "source": "google",
      "googleFamily": "DM Sans",
      "cssUrl": "https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap"
    }
  ],
  "playground": {
    "canvas": "#ffffff",
    "ink": "#0a0a0a",
    "surface": "#f7f8fa",
    "hairline": "#e5e7eb",
    "muted": "#a8aab2",
    "radiusMd": "8px",
    "buttonPrimary": {
      "backgroundColor": "#0a0a0a",
      "color": "#ffffff",
      "padding": "11px 24px",
      "borderRadius": "9999px",
      "fontFamily": "\"DM Sans\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "600",
      "lineHeight": "1.4",
      "cursor": "default",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center"
    },
    "buttonSecondary": {
      "backgroundColor": "transparent",
      "color": "#0a0a0a",
      "padding": "11px 24px",
      "borderRadius": "9999px",
      "border": "1px solid #0a0a0a",
      "fontFamily": "\"DM Sans\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "600",
      "lineHeight": "1.4",
      "cursor": "default",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center"
    },
