    "heading-md": {
      "fontFamily": "DM Sans",
      "fontSize": "32px",
      "fontWeight": 600,
      "lineHeight": 1.25,
      "letterSpacing": "-0.5px"
    },
    "heading-sm": {
      "fontFamily": "DM Sans",
      "fontSize": "24px",
      "fontWeight": 600,
      "lineHeight": 1.3
