    "product-matrix-grid": {
      "backgroundColor": "{colors.canvas}",
      "rounded": "{rounded.hero}",
      "padding": "{spacing.xxl}"
    },
    "ai-product-matrix": {
      "backgroundColor": "{colors.canvas}",
      "rounded": "{rounded.xxxl}",
      "padding": "{spacing.xl}",
      "border": "1px solid {colors.hairline}"
