    "badge-new": {
      "backgroundColor": "{colors.brand-coral}",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.caption-bold}",
      "rounded": "{rounded.full}",
      "padding": "4px 10px"
    },
    "badge-beta": {
      "backgroundColor": "{colors.brand-blue-200}",
      "textColor": "{colors.brand-blue-deep}",
      "typography": "{typography.caption-bold}",
      "rounded": "{rounded.full}",
      "padding": "4px 10px"
