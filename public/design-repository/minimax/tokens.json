      "fontFamily": "\"DM Sans\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5"
    },
    "headline": {
      "fontFamily": "\"DM Sans\", system-ui, sans-serif",
      "fontSize": "20px",
      "fontWeight": "600",
      "lineHeight": "1.4"
    },
    "card": {
      "backgroundColor": "#ff5530",
      "color": "#ffffff",
      "padding": "32px",
      "borderRadius": "32px",
      "border": "1px solid #e5e7eb",
      "fontFamily": "\"DM Sans\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5"
    },
    "input": {
      "backgroundColor": "#ffffff",
      "color": "#0a0a0a",
      "padding": "12px 16px",
      "borderRadius": "8px",
      "border": "1px solid #e5e7eb",
      "fontFamily": "\"DM Sans\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "width": "100%",
      "boxSizing": "border-box"
    },
    "badge": {
      "backgroundColor": "#e8ffea",
      "color": "#1ba673",
      "padding": "4px 10px",
      "borderRadius": "9999px",
      "fontFamily": "\"DM Sans\", system-ui, sans-serif",
      "fontSize": "13px",
      "fontWeight": "600",
      "lineHeight": "1.5",
      "display": "inline-block"
    },
    "link": {
      "backgroundColor": "transparent",
      "color": "#a8aab2",
      "padding": "4px 0",
      "fontFamily": "\"DM Sans\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "textDecoration": "underline",
      "textUnderlineOffset": "2px",
      "cursor": "default"
    },
    "nav": {
      "bar": {
        "backgroundColor": "transparent",
        "color": "#222222",
        "padding": "8px 16px",
        "borderRadius": "6px",
        "fontFamily": "\"DM Sans\", system-ui, sans-serif",
        "fontSize": "14px",
        "fontWeight": "400",
        "lineHeight": "1.5",
        "border": "1px solid #e5e7eb",
        "display": "flex",
        "alignItems": "center",
        "gap": "20px",
        "flexWrap": "wrap"
      },
      "link": {
        "fontFamily": "\"DM Sans\", system-ui, sans-serif",
        "fontSize": "14px",
        "fontWeight": "400",
        "lineHeight": "1.5",
        "backgroundColor": "transparent",
        "color": "#a8aab2",
        "padding": "4px 0"
      },
      "linkActive": {
        "fontFamily": "\"DM Sans\", system-ui, sans-serif",
        "fontSize": "14px",
        "fontWeight": "400",
        "lineHeight": "1.5",
        "backgroundColor": "transparent",
        "color": "#0a0a0a",
        "padding": "4px 0"
      }
    },
    "tabActive": {
      "backgroundColor": "#0a0a0a",
      "color": "#ffffff",
      "borderRadius": "9999px",
      "border": "1px solid #0a0a0a",
      "padding": "8px 14px",
      "fontFamily": "\"DM Sans\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "cursor": "default",
      "display": "inline-block"
    },
    "tabInactive": {
      "backgroundColor": "#ffffff",
      "color": "#5f5f5f",
      "padding": "8px 16px",
      "borderRadius": "9999px",
      "border": "1px solid #e5e7eb",
      "fontFamily": "\"DM Sans\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "500",
      "lineHeight": "1.5",
      "cursor": "default",
      "display": "inline-block"
    },
    "alert": {
      "backgroundColor": "#0a0a0a",
      "color": "#ffffff",
      "padding": "12px 20px",
      "fontFamily": "\"DM Sans\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "500",
      "lineHeight": "1.5",
      "borderRadius": "8px",
      "border": "1px solid #e5e7eb",
      "borderLeft": "3px solid #0a0a0a"
    },
    "code": {
      "backgroundColor": "#bfdbfe",
      "color": "#1d4ed8",
      "padding": "2px 6px",
      "borderRadius": "6px",
      "fontFamily": "\"DM Sans\", system-ui, sans-serif",
      "fontSize": "13px",
      "fontWeight": "600",
      "lineHeight": "1.5",
      "display": "block",
      "overflowX": "auto"
    },
    "label": {
      "fontFamily": "\"DM Sans\", system-ui, sans-serif",
      "fontSize": "13px",
      "fontWeight": "400",
      "lineHeight": "1.7"
    },
    "accordion": {
      "backgroundColor": "#f7f8fa",
      "color": "#0a0a0a",
      "border": "1px solid #e5e7eb",
      "borderRadius": "8px",
      "summaryColor": "#0a0a0a",
      "summaryStyle": {
        "fontFamily": "\"DM Sans\", system-ui, sans-serif",
        "fontSize": "20px",
        "fontWeight": "600",
        "lineHeight": "1.4",
        "color": "#0a0a0a",
        "padding": "12px 16px"
      },
      "mutedColor": "#a8aab2"
    }
  }
}
