    "card-feature": {
      "backgroundColor": "{colors.surface}",
      "rounded": "{rounded.xl}",
      "padding": "{spacing.xxl}"
    },
    "card-recommendation": {
      "backgroundColor": "{colors.canvas}",
      "rounded": "{rounded.lg}",
      "padding": "{spacing.lg}",
      "border": "1px solid {colors.hairline}"
