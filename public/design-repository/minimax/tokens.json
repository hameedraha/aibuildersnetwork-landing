      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.steel}",
      "typography": "{typography.body-sm-medium}",
      "rounded": "{rounded.full}",
      "padding": "{spacing.xs} {spacing.md}",
      "border": "1px solid {colors.hairline}"
