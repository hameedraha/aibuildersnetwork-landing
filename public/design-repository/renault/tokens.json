{
  "colors": {
    "primary": "#ffed00",
    "primary-deep": "#e6d200",
    "on-primary": "#000000",
    "ink": "#000000",
    "body": "#222222",
    "charcoal": "#333333",
    "mute": "#666666",
    "ash": "#8a8a8a",
    "stone": "#c4c4c4",
    "on-dark": "#ffffff",
    "on-dark-mute": "rgba(255,255,255,0.72)",
    "canvas": "#ffffff",
    "surface-soft": "#f7f7f7",
    "surface-card": "#ffffff",
    "surface-dark": "#000000",
    "surface-deep": "#111111",
    "hairline": "#f2f2f2",
    "hairline-strong": "#000000",
    "divider-dark": "rgba(255,255,255,0.16)",
    "badge-new": "#ffed00",
    "link": "#0000ee",
    "error": "#be6464",
    "warning": "#f0ad4e",
    "success": "#8dc572",
    "info": "#337ab7"
  },
  "primaryColors": {
    "primary": "#ffed00",
    "primary-deep": "#e6d200",
    "on-primary": "#000000"
  },
  "typography": {
    "display-xl": {
      "fontFamily": "NouvelR",
      "fontSize": "56px",
      "fontWeight": 700,
      "lineHeight": 0.95,
      "letterSpacing": 0
    },
    "display-lg": {
      "fontFamily": "NouvelR",
      "fontSize": "40px",
      "fontWeight": 700,
      "lineHeight": 0.95,
      "letterSpacing": 0
    },
    "display-md": {
      "fontFamily": "NouvelR",
      "fontSize": "32px",
      "fontWeight": 700,
      "lineHeight": 0.95,
      "letterSpacing": 0
    },
    "heading-lg": {
      "fontFamily": "NouvelR",
      "fontSize": "24px",
      "fontWeight": 700,
      "lineHeight": 0.95,
      "letterSpacing": 0
    },
    "heading-md": {
      "fontFamily": "NouvelR",
      "fontSize": "20px",
      "fontWeight": 700,
      "lineHeight": 0.95,
      "letterSpacing": 0
    },
    "heading-sm": {
      "fontFamily": "NouvelR",
      "fontSize": "18px",
      "fontWeight": 700,
      "lineHeight": 1,
      "letterSpacing": 0
    },
    "subtitle": {
      "fontFamily": "NouvelR",
      "fontSize": "19.2px",
      "fontWeight": 600,
      "lineHeight": 1.3,
      "letterSpacing": 0
    },
    "body-lg": {
      "fontFamily": "NouvelR",
      "fontSize": "18px",
      "fontWeight": 400,
      "lineHeight": 1.5,
      "letterSpacing": 0
    },
    "body-md": {
      "fontFamily": "NouvelR",
      "fontSize": "16px",
      "fontWeight": 400,
      "lineHeight": 1.4,
      "letterSpacing": 0
    },
    "body-sm": {
      "fontFamily": "NouvelR",
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": 1.57,
      "letterSpacing": 0
    },
    "button-lg": {
      "fontFamily": "NouvelR",
      "fontSize": "16px",
      "fontWeight": 700,
      "lineHeight": 1,
      "letterSpacing": 0
    },
    "button-md": {
      "fontFamily": "NouvelR",
      "fontSize": "14.4px",
      "fontWeight": 700,
      "lineHeight": 1,
      "letterSpacing": "0.144px"
    },
    "button-sm": {
      "fontFamily": "NouvelR",
      "fontSize": "13px",
      "fontWeight": 600,
      "lineHeight": 1.2,
      "letterSpacing": "0.13px"
    },
    "caption": {
      "fontFamily": "NouvelR",
      "fontSize": "12px",
      "fontWeight": 400,
      "lineHeight": 1.4,
      "letterSpacing": 0
    },
    "overline": {
      "fontFamily": "NouvelR",
      "fontSize": "10px",
      "fontWeight": 700,
      "lineHeight": 1.45,
      "letterSpacing": 0
    }
  },
  "components": {
    "button-primary": {
      "backgroundColor": "{colors.primary}",
      "textColor": "{colors.on-primary}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.xs}",
      "padding": "14px 24px",
      "height": "48px"
    },
    "button-primary-pressed": {
      "backgroundColor": "{colors.primary-deep}",
      "textColor": "{colors.on-primary}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.xs}"
    },
    "button-secondary-dark": {
      "backgroundColor": "{colors.surface-dark}",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.xs}",
      "padding": "14px 24px"
    },
    "button-outline-dark": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.xs}",
      "padding": "13px 23px"
    },
    "button-outline-light": {
      "backgroundColor": "{colors.surface-dark}",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.xs}",
      "padding": "13px 23px"
    },
    "button-pill": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.button-sm}",
      "rounded": "{rounded.pill}",
      "padding": "8px 16px",
      "height": "36px"
    },
    "button-icon-square": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "rounded": "{rounded.xs}",
      "size": "40px"
    },
    "text-input": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.none}",
      "padding": "12px 16px",
      "height": "48px"
    },
    "hero-banner": {
      "backgroundColor": "{colors.surface-dark}",
      "textColor": "{colors.on-dark}",
      "rounded": "{rounded.none}",
      "padding": 0
    },
    "promo-tile-light": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.heading-lg}",
      "rounded": "{rounded.none}",
      "padding": "32px"
    },
    "promo-tile-dark": {
      "backgroundColor": "{colors.surface-dark}",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.heading-lg}",
      "rounded": "{rounded.none}",
      "padding": "32px"
    },
    "promo-tile-yellow": {
      "backgroundColor": "{colors.primary}",
      "textColor": "{colors.on-primary}",
      "typography": "{typography.heading-lg}",
      "rounded": "{rounded.none}",
      "padding": "32px"
    },
    "vehicle-card": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "rounded": "{rounded.none}",
      "padding": 0
    },
    "configurator-row": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.none}",
      "padding": "24px 0"
    },
    "configurator-swatch": {
      "backgroundColor": "{colors.surface-soft}",
      "rounded": "{rounded.full}",
      "size": "56px"
    },
    "badge-new": {
      "backgroundColor": "{colors.badge-new}",
      "textColor": "{colors.on-primary}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.full}",
      "padding": "6px 14px"
    },
    "nav-bar": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.none}",
      "height": "60px"
    },
    "sub-nav-pill": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.button-sm}",
      "rounded": "{rounded.pill}",
      "padding": "8px 16px"
    },
    "footer": {
      "backgroundColor": "{colors.surface-dark}",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.body-sm}",
      "rounded": "{rounded.none}",
      "padding": "64px 24px"
    }
  },
  "rounded": {
    "none": "0px",
    "xs": "2px",
    "sm": "3px",
    "md": "4px",
    "pill": "46px",
    "full": "9999px"
  },
  "fonts": [
    {
      "name": "NouvelR",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    }
  ],
  "playground": {
    "canvas": "#ffffff",
    "ink": "#000000",
    "surface": "#ffffff",
    "hairline": "#f2f2f2",
    "muted": "#222222",
    "radiusMd": "4px",
    "buttonPrimary": {
      "backgroundColor": "#ffed00",
      "color": "#000000",
      "padding": "14px 24px",
      "borderRadius": "2px",
      "fontFamily": "\"NouvelR\", system-ui, sans-serif",
      "fontSize": "14.4px",
      "fontWeight": "700",
      "lineHeight": "1",
      "letterSpacing": "0.144px",
      "cursor": "default",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center"
    },
    "buttonSecondary": {
      "backgroundColor": "#000000",
      "color": "#ffffff",
      "padding": "14px 24px",
      "borderRadius": "2px",
      "fontFamily": "\"NouvelR\", system-ui, sans-serif",
      "fontSize": "14.4px",
      "fontWeight": "700",
      "lineHeight": "1",
      "letterSpacing": "0.144px",
      "cursor": "default",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center"
    },
    "body": {
      "fontFamily": "\"NouvelR\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.4"
    },
    "headline": {
      "fontFamily": "\"NouvelR\", system-ui, sans-serif",
      "fontSize": "32px",
      "fontWeight": "700",
      "lineHeight": "0.95"
    },
    "card": {
      "backgroundColor": "#ffffff",
      "color": "#000000",
      "padding": "24px",
      "borderRadius": "4px",
      "border": "1px solid #f2f2f2",
      "fontFamily": "\"NouvelR\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.4"
    },
    "input": {
      "backgroundColor": "#ffffff",
      "color": "#000000",
      "padding": "12px 16px",
      "fontFamily": "\"NouvelR\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.4",
      "borderRadius": "4px",
      "border": "1px solid #f2f2f2",
      "width": "100%",
      "boxSizing": "border-box"
    },
    "badge": {
      "backgroundColor": "#ffed00",
      "color": "#000000",
      "padding": "6px 14px",
      "borderRadius": "9999px",
      "fontFamily": "\"NouvelR\", system-ui, sans-serif",
      "fontSize": "14.4px",
      "fontWeight": "700",
      "lineHeight": "1",
      "letterSpacing": "0.144px",
      "display": "inline-block"
    },
    "link": {
      "color": "#0000ee",
      "textDecoration": "underline",
      "textUnderlineOffset": "2px",
      "fontFamily": "\"NouvelR\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.4",
      "cursor": "default"
    },
    "nav": {
      "bar": {
        "backgroundColor": "#ffffff",
        "color": "#000000",
        "fontFamily": "\"NouvelR\", system-ui, sans-serif",
        "fontSize": "14.4px",
        "fontWeight": "700",
        "lineHeight": "1",
        "letterSpacing": "0.144px",
        "border": "1px solid #f2f2f2",
        "borderRadius": "4px",
        "padding": "12px 16px",
        "display": "flex",
        "alignItems": "center",
        "gap": "20px",
        "flexWrap": "wrap"
      },
      "link": {
        "fontFamily": "\"NouvelR\", system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": "400",
        "lineHeight": "1.4",
        "color": "#000000"
      },
      "linkActive": {
        "fontFamily": "\"NouvelR\", system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": "400",
        "lineHeight": "1.4",
        "color": "#ffed00"
      }
    },
    "tabActive": {
      "backgroundColor": "#ffed00",
      "color": "#000000",
      "padding": "8px 14px",
      "borderRadius": "4px",
      "fontFamily": "\"NouvelR\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.4",
      "cursor": "default",
      "display": "inline-block"
    },
    "tabInactive": {
      "backgroundColor": "#ffffff",
      "color": "#000000",
      "border": "1px solid #f2f2f2",
      "padding": "8px 14px",
      "borderRadius": "4px",
      "fontFamily": "\"NouvelR\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.4",
      "cursor": "default",
      "display": "inline-block"
    },
    "alert": {
      "backgroundColor": "#000000",
      "color": "#ffffff",
      "padding": "12px 16px",
      "borderRadius": "4px",
      "border": "1px solid #f2f2f2",
      "borderLeft": "3px solid #ffed00",
      "fontFamily": "\"NouvelR\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.4"
    },
    "code": {
      "backgroundColor": "#000000",
      "color": "#f4f1ea",
      "padding": "14px 16px",
      "borderRadius": "4px",
      "fontFamily": "\"DM Mono\", ui-monospace, monospace",
      "fontSize": "13px",
      "lineHeight": "1.5",
      "display": "block",
      "overflowX": "auto"
    },
    "label": {
      "fontFamily": "\"NouvelR\", system-ui, sans-serif",
      "fontSize": "12px",
      "fontWeight": "400",
      "lineHeight": "1.4"
    },
    "accordion": {
      "backgroundColor": "#ffffff",
      "color": "#000000",
      "border": "1px solid #f2f2f2",
      "borderRadius": "4px",
      "summaryColor": "#000000",
      "summaryStyle": {
        "fontFamily": "\"NouvelR\", system-ui, sans-serif",
        "fontSize": "32px",
        "fontWeight": "700",
        "lineHeight": "0.95",
        "color": "#000000",
        "padding": "12px 16px"
      },
      "mutedColor": "#222222"
    }
  }
}
