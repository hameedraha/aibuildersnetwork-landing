  "rounded": {
    "none": "0px",
    "xs": "1px",
    "sm": "2px",
    "full": "9999px"
  },
  "fonts": [
    {
      "name": "NVIDIA-EMEA",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    }
  ],
