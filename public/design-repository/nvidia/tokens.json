        "fontWeight": "400",
        "lineHeight": "1.5",
        "color": "#76b900"
      }
    },
    "tabActive": {
      "backgroundColor": "#000000",
      "color": "#ffffff",
      "borderRadius": "2px",
      "fontFamily": "\"NVIDIA-EMEA\", system-ui, sans-serif",
      "fontSize": "14.4px",
      "fontWeight": "700",
      "lineHeight": "1",
      "letterSpacing": "0.144px",
      "padding": "8px 14px",
      "cursor": "default",
      "display": "inline-block"
