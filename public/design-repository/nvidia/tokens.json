        "fontWeight": "700",
        "lineHeight": "1.5",
        "border": "1px solid #cccccc",
        "borderRadius": "2px",
        "padding": "12px 16px",
        "display": "flex",
        "alignItems": "center",
        "gap": "20px",
        "flexWrap": "wrap"
