      "fontSize": "14.4px",
      "fontWeight": "700",
      "lineHeight": "1",
      "letterSpacing": "0.144px",
      "border": "1px solid #cccccc",
      "cursor": "default",
      "display": "inline-block"
    },
    "alert": {
      "backgroundColor": "#ffffff",
      "color": "#000000",
      "padding": "32px",
      "borderRadius": "2px",
      "fontFamily": "\"NVIDIA-EMEA\", system-ui, sans-serif",
      "fontSize": "36px",
      "fontWeight": "700",
      "lineHeight": "1.25",
      "border": "1px solid #cccccc",
      "borderLeft": "3px solid #76b900"
