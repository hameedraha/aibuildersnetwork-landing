  "rounded": {
    "none": "0px",
    "full": "9999px"
  },
  "fonts": [
    {
      "name": "Arial Black",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    },
    {
      "name": "Helvetica",
      "source": "google",
      "googleFamily": "Helvetica",
      "cssUrl": "https://fonts.googleapis.com/css2?family=Helvetica:wght@300;400;500;600;700&display=swap"
    },
    {
      "name": "Times New Roman",
      "source": "google",
      "googleFamily": "Times New Roman",
      "cssUrl": "https://fonts.googleapis.com/css2?family=Times+New+Roman:wght@300;400;500;600;700&display=swap"
    }
  ],
