      "letterSpacing": "-0.65px"
    },
    "display-lg": {
      "fontFamily": "Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif",
      "fontSize": "36px",
      "fontWeight": 400,
      "lineHeight": "40px",
      "letterSpacing": "-0.9px"
    },
    "display-md": {
      "fontFamily": "Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif",
      "fontSize": "24px",
      "fontWeight": 700,
      "lineHeight": "32px",
      "letterSpacing": "-0.6px"
    },
    "display-sm": {
      "fontFamily": "Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif",
      "fontSize": "20px",
      "fontWeight": 600,
      "lineHeight": "28px"
