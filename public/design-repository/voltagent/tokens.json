    "body-sm": {
      "fontFamily": "Inter, system-ui, -apple-system, sans-serif",
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": "20px"
    },
    "body-sm-strong": {
      "fontFamily": "Inter, system-ui, -apple-system, sans-serif",
      "fontSize": "14px",
      "fontWeight": 600,
      "lineHeight": "23px"
