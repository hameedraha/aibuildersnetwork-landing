    "caption-strong": {
      "fontFamily": "Inter, system-ui, -apple-system, sans-serif",
      "fontSize": "12px",
      "fontWeight": 500,
      "lineHeight": "16px"
    },
    "code": {
      "fontFamily": "SFMono-Regular, Menlo, Monaco, Consolas, Liberation Mono, monospace",
      "fontSize": "13px",
      "fontWeight": 400,
      "lineHeight": "18px"
    },
    "code-strong": {
      "fontFamily": "SFMono-Regular, Menlo, Monaco, Consolas, monospace",
      "fontSize": "13px",
      "fontWeight": 550,
      "lineHeight": "16px"
