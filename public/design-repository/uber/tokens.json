      "description": "Toast notification surface — flat-cornered card-content chrome with Level 2 drop shadow.",
      "backgroundColor": "{colors.canvas}",
      "rounded": "{rounded.xl}",
      "padding": "{spacing.md} {spacing.lg}",
      "typography": "{typography.body-sm}"
    }
