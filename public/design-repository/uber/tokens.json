    "none": "0px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "pill": "999px",
    "pill-tab": "36px",
    "full": "9999px"
  },
  "fonts": [
    {
      "name": "UberMove, UberMoveText, system-ui, Helvetica Neue, Arial, sans-serif",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    },
    {
      "name": "UberMoveText, system-ui, Helvetica Neue, Arial, sans-serif",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    }
  ],
