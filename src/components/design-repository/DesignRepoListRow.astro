---
import type { DesignRepoEntry } from '../../data/design-repository.types';
import DesignRepoColorChips from './DesignRepoColorChips.astro';

interface Props {
  entry: DesignRepoEntry;
}

const { entry } = Astro.props;
const searchText = `${entry.displayName} ${entry.name} ${entry.description} ${entry.category} ${entry.colorFamily}`.toLowerCase();
---

<a
  href={`/design-repository/${entry.slug}`}
  class="design-repo-list-row"
  data-design-repo-item
  data-search={searchText}
  data-category={entry.category}
  data-color-family={entry.colorFamily}
>
  {entry.logo ? (
    <img
      src={entry.logo}
      alt=""
      class="design-repo-list-row__logo"
      width="32"
      height="32"
      loading="lazy"
      decoding="async"
    />
  ) : (
    <span class="design-repo-list-row__logo-fallback" aria-hidden="true">
      {entry.displayName.charAt(0)}
    </span>
  )}
  <span class="design-repo-list-row__name heading">{entry.displayName}</span>
  <span class="design-repo-list-row__category eyebrow">{entry.category}</span>
  <DesignRepoColorChips colors={entry.primaryColors} size="sm" />
  <span class="design-repo-list-row__desc body-md">{entry.description}</span>
  <span class="design-repo-list-row__arrow" aria-hidden="true">→</span>
</a>
