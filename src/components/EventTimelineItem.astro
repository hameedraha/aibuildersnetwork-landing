---
import type { CollectionEntry } from 'astro:content';
import type { EventStatus } from '../../lib/event-status';
import { getEventStatusLabel, toEventDateKey } from '../../lib/event-status';
import { getEventSlug } from '../utils/eventSlug';

interface Props {
  event: CollectionEntry<'events'>;
  status: EventStatus;
  showLine?: boolean;
}

const { event, status, showLine = true } = Astro.props;
const { title, description, eventDate, format, location, price, ticketUrl } = event.data;

const dateLabel = eventDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
const statusLabel = getEventStatusLabel(status);
const eventDateKey = toEventDateKey(eventDate);
const isPast = status === 'past';
---

<li
  class:list={['events-timeline__item', `events-timeline__item--${status}`]}
  data-event-root
  data-event-date={eventDateKey}
  data-event-status={status}
>
  <div class="events-timeline__rail" aria-hidden="true">
    <span class="events-timeline__marker"></span>
    {showLine && <span class="events-timeline__line"></span>}
  </div>

  <article class="events-timeline__card">
    <header class="events-timeline__header">
      <time class="eyebrow" datetime={eventDate.toISOString()}>{dateLabel}</time>
      <span class:list={['events-timeline__status', status === 'live' && 'events-timeline__status--live']}>
        <span data-event-status-text>{statusLabel}</span>
      </span>
    </header>

    <p class="eyebrow events-timeline__format">{format}</p>
    <h3 class="heading">
      <a href={`/events/${getEventSlug(event)}`}>{title}</a>
    </h3>
    <p class="body-md events-timeline__desc">{description}</p>

    <footer class="events-timeline__footer">
      <span class="body-md">{location}</span>
      <span class="heading">{price}</span>
    </footer>

    <div class="events-timeline__links">
      <a href={`/events/${getEventSlug(event)}`} class="events-timeline__link">details →</a>
      <a
        href={ticketUrl}
        class="events-timeline__link events-timeline__link--accent"
        data-event-ticket
        hidden={isPast}
        target="_blank"
        rel="noopener noreferrer"
      >
        tickets →
      </a>
    </div>
  </article>
</li>
