---
interface Props {
  title: string;
  description: string;
  eyebrow?: string;
}

const { title, description, eyebrow = 'coming soon' } = Astro.props;
---

<div class="coming-soon section--neutral">
  <div class="container coming-soon__inner">
    <span class="eyebrow">{eyebrow}</span>
    <h1 class="display-l">{title}</h1>
    <p class="body-lg coming-soon__desc">{description}</p>
    <div class="coming-soon__grid" role="presentation">
      <div class="coming-soon__cell">
        <span class="dot-bullet" aria-hidden="true">
          <span></span><span></span><span class="accent"></span><span></span>
        </span>
        <p class="body-md">we're building this in public. check back soon.</p>
      </div>
      <div class="coming-soon__cell">
        <span class="dot-bullet" aria-hidden="true">
          <span></span><span></span><span class="accent"></span><span></span>
        </span>
        <p class="body-md">join the network to hear when it launches.</p>
      </div>
    </div>
    <a href="/community" class="btn-primary">
      join the network
    </a>
  </div>
</div>

<style>
  .coming-soon {
    padding-block: clamp(80px, 14vw, 140px);
    flex: 1;
    display: flex;
    align-items: center;
  }
  .coming-soon__inner {
    max-width: 640px;
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
  }
  .coming-soon__desc {
    color: var(--c-muted);
    max-width: 48ch;
  }
  .coming-soon__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--c-divider);
    border: 1px solid var(--c-divider);
    margin-block: var(--sp-sm);
  }
  .coming-soon__cell {
    background: var(--c-surface);
    padding: var(--sp-md);
    display: flex;
    align-items: flex-start;
    gap: var(--sp-sm);
  }
  .coming-soon__cell .body-md {
    color: var(--c-muted);
  }
  @media (max-width: 640px) {
    .coming-soon__grid { grid-template-columns: 1fr; }
  }
</style>
