---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResourceCard from '../components/ResourceCard.astro';
import { getCollection } from 'astro:content';
import { getEventSlug } from '../utils/eventSlug';
import { pickHomeEvent, resolveEvents, sortEventsByDate } from '../utils/events';

const latestResources = (await getCollection('resources') ?? [])
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const homeEvent = pickHomeEvent(resolveEvents(sortEventsByDate(await getCollection('events') ?? [])));

const eventDateLabel = homeEvent
  ? homeEvent.event.data.eventDate.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' })
  : '';
---

<BaseLayout title="ai builders network" headerReveal={true}>
  <style>
    /* ── HERO LOGO ANIMATION ── */
    @keyframes logo-in {
      from { opacity: 0; transform: scale(0.85); }
      to   { opacity: 1; transform: scale(1); }
    }
    .hero-logo-img {
      animation: logo-in 0.5s cubic-bezier(0.2, 0, 0, 1) both;
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-logo-img { animation: none; }
    }

    /* ═══════════════════════════════
       HERO
    ═══════════════════════════════ */
    .hero {
      padding-block: clamp(80px, 14vw, 160px);
    }
    .hero__inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: var(--sp-md);
    }
    .hero__inner .display-xl {
      max-width: 16ch;
    }
    .hero__inner .body-lg {
      max-width: 46ch;
      color: var(--c-muted);
    }
    .hero__inner .btn-primary {
      margin-top: var(--sp-xs);
    }

    /* ═══════════════════════════════
       WHAT THIS IS
    ═══════════════════════════════ */
    .what {
      padding-block: clamp(48px, 10vw, 120px);
    }
    .what-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 2px;
      background: rgba(244, 241, 234, 0.2);
    }
    .what-grid__cell {
      background: var(--c-ink);
      padding: var(--sp-lg);
      display: flex;
      flex-direction: column;
      gap: var(--sp-sm);
    }
    .what-grid__cell .heading {
      color: var(--c-on-ink);
    }
    .what-grid__cell .body-md {
      color: rgba(244, 241, 234, 0.65);
    }

    /* ═══════════════════════════════
       BENEFITS
    ═══════════════════════════════ */
    .benefits {
      padding-block: clamp(48px, 10vw, 120px);
    }
    .benefits .eyebrow {
      display: block;
      margin-bottom: var(--sp-sm);
    }
    .benefits .display-l {
      margin-bottom: var(--sp-lg);
    }
    .benefit-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 1px;
      background: var(--c-divider);
      border: 1px solid var(--c-divider);
    }
    .benefit-card {
      background: var(--c-surface);
      padding: var(--sp-lg);
      display: flex;
      flex-direction: column;
      gap: var(--sp-md);
    }
    .benefit-card__header {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .benefit-card .body-md {
      color: var(--c-muted);
    }

    /* ═══════════════════════════════
       RESOURCES PREVIEW
    ═══════════════════════════════ */
    .resources-preview {
      padding-block: clamp(48px, 10vw, 120px);
    }
    .resources-preview .eyebrow {
      display: block;
      margin-bottom: var(--sp-sm);
    }
    .resources-preview__header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: var(--sp-md);
      margin-bottom: var(--sp-lg);
      flex-wrap: wrap;
    }
    .resources-preview__header .display-l {
      margin-bottom: 0;
    }

    /* ═══════════════════════════════
       FIT CHECK
    ═══════════════════════════════ */
    .fit {
      padding-block: clamp(48px, 10vw, 120px);
    }
    .fit .eyebrow {
      display: block;
      margin-bottom: var(--sp-sm);
    }
    .fit .display-l {
      color: var(--c-on-ink);
      margin-bottom: var(--sp-lg);
    }
    .fit-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      background: rgba(244, 241, 234, 0.2);
    }
    .fit-col {
      background: var(--c-ink);
      padding: var(--sp-lg);
    }
    .fit-col__label {
      display: block;
      margin-bottom: var(--sp-md);
    }
    .fit-list {
      display: flex;
      flex-direction: column;
      gap: var(--sp-sm);
    }
    .fit-list li {
      display: flex;
      align-items: flex-start;
      gap: var(--sp-sm);
    }
    .fit-list li .dot-bullet {
      margin-top: 6px;
      color: var(--c-on-ink);
    }
    .fit-list li span:last-child {
      font-family: var(--f-body);
      font-size: 1rem;
      line-height: 1.6;
      color: rgba(244, 241, 234, 0.75);
    }
    .fit-list--no li span:last-child {
      color: rgba(244, 241, 234, 0.4);
    }
    .fit-list--no li .dot-bullet span.accent {
      background: var(--c-muted);
    }

    /* ═══════════════════════════════
       FINAL CTA
    ═══════════════════════════════ */
    .cta-final {
      padding-block: clamp(48px, 10vw, 120px);
    }
    .cta-final__inner {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: var(--sp-md);
    }
    .cta-final .eyebrow {
      margin-bottom: 0;
    }
    .cta-final .display-l {
      margin-bottom: var(--sp-sm);
    }
    .cta-final__footnote {
      color: var(--c-muted);
      margin-top: var(--sp-xs);
    }

    /* ═══════════════════════════════
       NEXT EVENT
    ═══════════════════════════════ */
    .next-event {
      padding-block: clamp(48px, 10vw, 120px);
    }
    .next-event .eyebrow {
      display: block;
      margin-bottom: var(--sp-md);
    }
    .next-event__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--sp-md);
      margin-bottom: var(--sp-md);
    }
    .next-event__header .eyebrow {
      margin-bottom: 0;
    }
    .event-card__body .display-l a:hover {
      color: var(--c-primary);
    }
    .event-card {
      display: grid;
      grid-template-columns: 1fr 280px;
      border: 1px solid var(--c-divider);
    }
    .event-card__body {
      padding: var(--sp-lg);
      border-right: 1px solid var(--c-divider);
      display: flex;
      flex-direction: column;
      gap: var(--sp-md);
    }
    .event-card__tag {
      color: var(--c-primary);
      margin-bottom: 0;
    }
    .event-card__body .display-l {
      margin-bottom: 0;
    }
    .event-card__desc {
      color: var(--c-muted);
      max-width: 52ch;
    }
    .event-hosts {
      display: flex;
      flex-direction: column;
      gap: 4px;
      margin-top: auto;
      padding-top: var(--sp-md);
      border-top: 1px solid rgba(26, 26, 26, 0.1);
    }
    .event-hosts .eyebrow {
      margin-bottom: 0;
    }
    .event-card__meta {
      padding: var(--sp-lg);
      display: flex;
      flex-direction: column;
      gap: var(--sp-md);
      background: var(--c-surface);
    }
    .event-meta-item {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .event-meta-item .eyebrow {
      margin-bottom: 0;
    }
    .event-card__meta .btn-primary {
      margin-top: auto;
      text-align: center;
    }

    @media (max-width: 640px) {
      .what-grid,
      .benefit-grid,
      .fit-grid {
        grid-template-columns: 1fr;
      }
      .event-card {
        grid-template-columns: 1fr;
      }
      .event-card__body {
        border-right: none;
        border-bottom: 1px solid var(--c-divider);
      }
    }
  </style>

  <!-- ═══════════════════════════════
       HERO
  ═══════════════════════════════ -->
  <section class="hero section--neutral" aria-label="hero" data-header-trigger>
    <div class="container hero__inner">
      <img src="/aibn-logo.svg" alt="aibn logo mark" class="logo-img logo-img--lg hero-logo-img" />
      <h1 class="display-xl">where builders ship ai.</h1>
      <p class="body-lg">a community of enthusiasts passionate about building AI solutions that shape the future.</p>
      <a href="/community" class="btn-primary">join the network</a>
    </div>
  </section>

  <div class="section-divider" role="separator"></div>

  <!-- ═══════════════════════════════
       WHAT THIS IS
  ═══════════════════════════════ -->
  <section class="what section--ink" aria-labelledby="what-heading">
    <div class="container">
      <div class="what-grid" role="presentation">
        <div class="what-grid__cell">
          <h2 class="heading" id="what-heading">a network of builders</h2>
          <p class="body-md">ai builders network is a gathering of people who ship AI-powered products, tools, and experiments. if you're wiring models to APIs at midnight or testing prompts on a side project — you belong here.</p>
        </div>
        <div class="what-grid__cell">
          <h3 class="heading">who it's for</h3>
          <p class="body-md">software engineers, indie founders, and curious makers who want peers, not an audience. people who care more about what ships than what sounds impressive.</p>
        </div>
        <div class="what-grid__cell">
          <h3 class="heading">how it works</h3>
          <p class="body-md">weekly build demos. async knowledge sharing. early access to each other's projects. accountability through showing up and sharing your work, rough edges included.</p>
        </div>
        <div class="what-grid__cell">
          <h3 class="heading">why now</h3>
          <p class="body-md">the tools changed in 2024. what one person can ship alone changed too. a small, focused group of serious builders compounds faster than any large, passive audience.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider" role="separator"></div>

  <!-- ═══════════════════════════════
       WHY JOIN / BENEFITS
  ═══════════════════════════════ -->
  <section class="benefits section--neutral" aria-labelledby="benefits-heading">
    <div class="container">
      <span class="eyebrow">why join</span>
      <h2 class="display-l" id="benefits-heading">the reasons are concrete.</h2>
      <div class="benefit-grid" role="presentation">

        <div class="benefit-card">
          <div class="benefit-card__header">
            <span class="dot-bullet" aria-hidden="true">
              <span></span><span></span><span class="accent"></span><span></span>
            </span>
            <h3 class="heading">peers who build</h3>
          </div>
          <p class="body-md">skip the theory. talk with people who shipped something this week and have the commits to prove it.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card__header">
            <span class="dot-bullet" aria-hidden="true">
              <span></span><span></span><span class="accent"></span><span></span>
            </span>
            <h3 class="heading">shared knowledge</h3>
          </div>
          <p class="body-md">real findings from real experiments — what model handles what task, what breaks under load, what actually makes it to users.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card__header">
            <span class="dot-bullet" aria-hidden="true">
              <span></span><span></span><span class="accent"></span><span></span>
            </span>
            <h3 class="heading">early idea access</h3>
          </div>
          <p class="body-md">see projects before they're polished. give feedback that shapes what gets built, not what gets announced.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card__header">
            <span class="dot-bullet" aria-hidden="true">
              <span></span><span></span><span class="accent"></span><span></span>
            </span>
            <h3 class="heading">built-in accountability</h3>
          </div>
          <p class="body-md">weekly demos keep you honest. nothing ships faster than knowing your peers will ask "so, what did you build this week?"</p>
        </div>

      </div>
    </div>
  </section>

  <div class="section-divider" role="separator"></div>

  <!-- ═══════════════════════════════
       RESOURCES
  ═══════════════════════════════ -->
  <section class="resources-preview section--neutral" aria-labelledby="resources-heading">
    <div class="container">
      <span class="eyebrow">resources</span>
      <div class="resources-preview__header">
        <h2 class="display-l" id="resources-heading">guides you can use today.</h2>
        <a href="/resources" class="btn-secondary btn--sm">see all resources</a>
      </div>
      <div class="resource-grid">
        {latestResources.map((resource) => (
          <ResourceCard resource={resource} />
        ))}
      </div>
    </div>
  </section>

  <div class="section-divider" role="separator"></div>

  <!-- ═══════════════════════════════
       WHO IT IS FOR
  ═══════════════════════════════ -->
  <section class="fit section--ink" aria-labelledby="fit-heading">
    <div class="container">
      <span class="eyebrow eyebrow--on-ink">who belongs here</span>
      <h2 class="display-l" id="fit-heading">filter yourself in.<br>or out.</h2>
      <div class="fit-grid" role="presentation">

        <div class="fit-col">
          <span class="fit-col__label eyebrow eyebrow--on-ink">you'll thrive here if —</span>
          <ul class="fit-list">
            <li>
              <span class="dot-bullet" aria-hidden="true"><span></span><span></span><span class="accent"></span><span></span></span>
              <span>you're building something with AI, however early or rough</span>
            </li>
            <li>
              <span class="dot-bullet" aria-hidden="true"><span></span><span></span><span class="accent"></span><span></span></span>
              <span>you're an engineer, founder, or maker who experiments hands-on</span>
            </li>
            <li>
              <span class="dot-bullet" aria-hidden="true"><span></span><span></span><span class="accent"></span><span></span></span>
              <span>you want peers, not a platform to broadcast at</span>
            </li>
            <li>
              <span class="dot-bullet" aria-hidden="true"><span></span><span></span><span class="accent"></span><span></span></span>
              <span>you care more about shipping than being right in a thread</span>
            </li>
            <li>
              <span class="dot-bullet" aria-hidden="true"><span></span><span></span><span class="accent"></span><span></span></span>
              <span>you're comfortable sharing half-finished ideas in public</span>
            </li>
          </ul>
        </div>

        <div class="fit-col fit-col--no">
          <span class="fit-col__label eyebrow eyebrow--on-ink">this isn't for you if —</span>
          <ul class="fit-list fit-list--no">
            <li>
              <span class="dot-bullet" aria-hidden="true"><span></span><span></span><span class="accent"></span><span></span></span>
              <span>you want to spectate without contributing</span>
            </li>
            <li>
              <span class="dot-bullet" aria-hidden="true"><span></span><span></span><span class="accent"></span><span></span></span>
              <span>you need polished content and finished answers only</span>
            </li>
            <li>
              <span class="dot-bullet" aria-hidden="true"><span></span><span></span><span class="accent"></span><span></span></span>
              <span>you're not ready to show your work publicly</span>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <div class="section-divider" role="separator"></div>

  <!-- ═══════════════════════════════
       NEXT EVENT
  ═══════════════════════════════ -->
  {homeEvent && (
    <>
      <section class="next-event section--neutral" aria-labelledby="event-heading">
        <div class="container">
          <div class="next-event__header">
            <span class="eyebrow" data-event-home-eyebrow>
              {homeEvent.status === 'live' ? 'happening now' : 'next event'}
            </span>
            <a href="/events" class="btn-secondary btn--sm">all events</a>
          </div>
          <div class="event-card">
            <div class="event-card__body">
              <p class="event-card__tag eyebrow">{homeEvent.event.data.format}</p>
              <h2 class="display-l" id="event-heading">
                <a href={`/events/${getEventSlug(homeEvent.event)}`}>{homeEvent.event.data.title}</a>
              </h2>
              <p class="body-lg event-card__desc">{homeEvent.event.data.description}</p>
              <div class="event-hosts">
                <span class="eyebrow">led by</span>
                <p class="body-md">{homeEvent.event.data.hosts.join(' · ')}</p>
              </div>
            </div>
            <div class="event-card__meta">
              <div class="event-meta-item">
                <span class="eyebrow">date</span>
                <span class="heading">{eventDateLabel}</span>
              </div>
              <div class="event-meta-item">
                <span class="eyebrow">location</span>
                <span class="body-md">{homeEvent.event.data.location}</span>
              </div>
              <div class="event-meta-item">
                <span class="eyebrow">price</span>
                <span class="heading">{homeEvent.event.data.price}</span>
              </div>
              <a href={homeEvent.event.data.ticketUrl} class="btn-primary" target="_blank" rel="noopener noreferrer">reserve your seat</a>
              <a href={`/events/${getEventSlug(homeEvent.event)}`} class="btn-secondary btn--sm" style="text-align:center;">event details</a>
            </div>
          </div>
        </div>
      </section>

      <div class="section-divider" role="separator"></div>
    </>
  )}

  <!-- ═══════════════════════════════
       FINAL CTA
  ═══════════════════════════════ -->
  <section class="cta-final section--neutral" aria-label="join the network">
    <div class="container cta-final__inner">
      <span class="eyebrow">ready to build</span>
      <h2 class="display-l">your next experiment<br>starts with the right people.</h2>
      <a href="/community" class="btn-primary">join the network</a>
      <p class="cta-final__footnote body-md">free to join · no spam · just builders building.</p>
    </div>
  </section>
</BaseLayout>
