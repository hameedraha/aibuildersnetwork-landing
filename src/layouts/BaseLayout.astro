---
interface Props {
  title: string;
  description?: string;
  headerReveal?: boolean;
}

const {
  title,
  description = 'a community for engineers, founders, and makers who build AI solutions.',
  headerReveal = false,
} = Astro.props;
const joinUrl = '/community';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/aibn-logo.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  <style is:global>
    /* ── RESET ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    ul { list-style: none; }
    a { text-decoration: none; color: inherit; }

    /* ── TOKENS ── */
    :root {
      --c-primary:      #C73E22;
      --c-primary-deep: #B83A22;
      --c-ink:          #1A1A1A;
      --c-on-ink:       #F4F1EA;
      --c-neutral:      #F4F1EA;
      --c-muted:        #5C5C5C;
      --c-surface:      #FFFFFF;
      --c-divider:      #1A1A1A;

      --f-display: 'DM Mono', monospace;
      --f-body:    'Inter', sans-serif;
      --f-mono:    'DM Mono', monospace;

      --sp-xs: 8px;
      --sp-sm: 16px;
      --sp-md: 24px;
      --sp-lg: 48px;
      --sp-xl: 120px;

      --r-sm: 4px;
      --r-md: 8px;

      --max-w:    1100px;
      --side-pad: clamp(20px, 5vw, 64px);
    }

    /* ── BASE ── */
    html { font-size: 16px; scroll-behavior: smooth; }
    body {
      background: var(--c-neutral);
      color: var(--c-ink);
      font-family: var(--f-body);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    main { flex: 1; }

    /* ── CONTAINER ── */
    .container {
      max-width: var(--max-w);
      margin: 0 auto;
      padding-inline: var(--side-pad);
    }

    /* ── TYPOGRAPHY ── */
    .display-xl {
      font-family: var(--f-display);
      font-size: clamp(3rem, 7vw, 5rem);
      font-weight: 500;
      line-height: 1.0;
      letter-spacing: -0.03em;
      text-transform: lowercase;
    }
    .display-l {
      font-family: var(--f-display);
      font-size: clamp(2rem, 5vw, 3.25rem);
      font-weight: 500;
      line-height: 1.05;
      letter-spacing: -0.02em;
      text-transform: lowercase;
    }
    .heading {
      font-family: var(--f-display);
      font-size: 1.25rem;
      font-weight: 500;
      line-height: 1.2;
      text-transform: lowercase;
    }
    .body-lg {
      font-family: var(--f-body);
      font-size: 1.25rem;
      font-weight: 400;
      line-height: 1.5;
    }
    .body-md {
      font-family: var(--f-body);
      font-size: 1rem;
      font-weight: 400;
      line-height: 1.6;
    }
    .eyebrow {
      font-family: var(--f-mono);
      font-size: 0.75rem;
      font-weight: 500;
      line-height: 1.4;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--c-muted);
    }
    .eyebrow--on-ink {
      color: rgba(244, 241, 234, 0.5);
    }

    /* ── SECTION BACKGROUNDS ── */
    .section--ink {
      background: var(--c-ink);
      color: var(--c-on-ink);
    }
    .section--neutral {
      background: var(--c-neutral);
      color: var(--c-ink);
    }

    /* ── SECTION DIVIDER ── */
    .section-divider {
      height: 1px;
      background: var(--c-divider);
      opacity: 0.15;
    }

    /* ── BUTTON ── */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--c-primary);
      color: var(--c-surface);
      font-family: var(--f-display);
      font-size: 1rem;
      font-weight: 500;
      line-height: 1.2;
      padding: 14px 24px;
      border-radius: var(--r-sm);
      border: none;
      cursor: pointer;
      transition: background 0.15s ease, transform 0.15s ease;
      white-space: nowrap;
      text-transform: lowercase;
    }
    .btn-primary:hover {
      background: var(--c-primary-deep);
      transform: translateY(-1px);
    }
    .btn--sm {
      font-size: 0.875rem;
      padding: 10px 18px;
    }
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      color: var(--c-ink);
      font-family: var(--f-display);
      font-size: 1rem;
      font-weight: 500;
      line-height: 1.2;
      padding: 14px 24px;
      border-radius: var(--r-sm);
      border: 1px solid var(--c-divider);
      cursor: pointer;
      transition: background 0.15s ease, transform 0.15s ease;
      white-space: nowrap;
      text-transform: lowercase;
    }
    .btn-secondary:hover {
      background: rgba(26, 26, 26, 0.04);
      transform: translateY(-1px);
    }

    /* ── LOGO ── */
    .logo-img {
      display: block;
      border-radius: var(--r-sm);
      flex-shrink: 0;
    }
    .logo-img--sm { width: 40px; height: 40px; }
    .logo-img--lg { width: 140px; height: 140px; }

    /* ── DOT BULLET ── */
    .dot-bullet {
      display: inline-grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      width: 9px;
      height: 9px;
      flex-shrink: 0;
    }
    .dot-bullet span {
      border-radius: 1px;
      background: currentColor;
      opacity: 0.25;
    }
    .dot-bullet span.accent {
      background: var(--c-primary);
      opacity: 1;
    }

    /* ═══════════════════════════════
       SHARED SECTION GRIDS
    ═══════════════════════════════ */
    .section-pad {
      padding-block: clamp(48px, 10vw, 120px);
    }
    .section-pad .eyebrow {
      display: block;
      margin-bottom: var(--sp-sm);
    }
    .section-pad .display-l {
      margin-bottom: var(--sp-lg);
    }
    .section--ink .display-l,
    .section--ink .heading {
      color: var(--c-on-ink);
    }

    .benefit-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 1px;
      background: var(--c-divider);
      border: 1px solid var(--c-divider);
    }
    .benefit-card {
      background: var(--c-surface);
      padding: var(--sp-lg);
      display: flex;
      flex-direction: column;
      gap: var(--sp-md);
    }
    .benefit-card__header {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .benefit-card .body-md {
      color: var(--c-muted);
    }

    .what-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 2px;
      background: rgba(244, 241, 234, 0.2);
    }
    .what-grid__cell {
      background: var(--c-ink);
      padding: var(--sp-lg);
      display: flex;
      flex-direction: column;
      gap: var(--sp-sm);
    }
    .what-grid__cell .heading {
      color: var(--c-on-ink);
    }
    .what-grid__cell .body-md {
      color: rgba(244, 241, 234, 0.65);
    }

    .fit-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      background: rgba(244, 241, 234, 0.2);
    }
    .fit-col {
      background: var(--c-ink);
      padding: var(--sp-lg);
    }
    .fit-col__label {
      display: block;
      margin-bottom: var(--sp-md);
    }
    .fit-list {
      display: flex;
      flex-direction: column;
      gap: var(--sp-sm);
    }
    .fit-list li {
      display: flex;
      align-items: flex-start;
      gap: var(--sp-sm);
    }
    .fit-list li .dot-bullet {
      margin-top: 6px;
      color: var(--c-on-ink);
    }
    .fit-list li span:last-child {
      font-family: var(--f-body);
      font-size: 1rem;
      line-height: 1.6;
      color: rgba(244, 241, 234, 0.75);
    }
    .fit-list--no li span:last-child {
      color: rgba(244, 241, 234, 0.55);
    }
    .fit-list--no li .dot-bullet {
      color: rgba(244, 241, 234, 0.35);
    }
    .fit-list--no li .dot-bullet span.accent {
      background: rgba(244, 241, 234, 0.35);
      opacity: 1;
    }

    @media (max-width: 640px) {
      .benefit-grid,
      .what-grid,
      .fit-grid {
        grid-template-columns: 1fr;
      }
    }

    /* ═══════════════════════════════
       COMMUNITY MODAL FORM
    ═══════════════════════════════ */
    .join-modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(26, 26, 26, 0.65);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--sp-md);
      z-index: 200;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.2s ease, visibility 0.2s ease;
    }
    .join-modal-overlay.is-open {
      opacity: 1;
      visibility: visible;
    }
    .join-modal {
      background: var(--c-surface);
      border-radius: var(--r-md);
      width: 100%;
      max-width: 520px;
      max-height: min(90vh, 720px);
      display: flex;
      flex-direction: column;
      transform: translateY(12px);
      transition: transform 0.2s ease;
      border: 1px solid rgba(26, 26, 26, 0.1);
      box-shadow: 0 24px 48px rgba(26, 26, 26, 0.18);
    }
    .join-modal-overlay.is-open .join-modal {
      transform: translateY(0);
    }
    .join-modal__header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--sp-md);
      padding: var(--sp-lg) var(--sp-lg) var(--sp-sm);
      flex-shrink: 0;
      border-bottom: 1px solid rgba(26, 26, 26, 0.08);
    }
    .join-modal__title {
      font-family: var(--f-display);
      font-size: 1.375rem;
      font-weight: 500;
      text-transform: lowercase;
      margin-bottom: 4px;
    }
    .join-modal__desc {
      color: var(--c-muted);
      font-size: 0.9375rem;
      line-height: 1.5;
      max-width: 36ch;
    }
    .join-modal__close {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border: 1px solid rgba(26, 26, 26, 0.12);
      border-radius: var(--r-sm);
      background: transparent;
      color: var(--c-ink);
      cursor: pointer;
      flex-shrink: 0;
      transition: background 0.15s ease;
    }
    .join-modal__close:hover {
      background: var(--c-neutral);
    }
    .community-form {
      display: flex;
      flex-direction: column;
      gap: var(--sp-md);
      border: none;
      margin: 0;
      padding: var(--sp-md) var(--sp-lg) var(--sp-lg);
      overflow-y: auto;
      width: 100%;
    }
    .community-fieldset {
      border: 1px solid rgba(26, 26, 26, 0.12);
      border-radius: var(--r-md);
      padding: var(--sp-md);
      margin: 0;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: var(--sp-md);
    }
    .community-fieldset legend {
      padding: 0 var(--sp-xs);
    }
    .community-label {
      display: flex;
      flex-direction: column;
      gap: var(--sp-xs);
    }
    .community-label__optional {
      font-family: var(--f-body);
      font-size: 0.875rem;
      font-weight: 400;
      color: var(--c-muted);
    }
    .community-input {
      font-family: var(--f-body);
      font-size: 1rem;
      padding: 10px 14px;
      border: 1px solid rgba(26, 26, 26, 0.15);
      border-radius: var(--r-sm);
      background: var(--c-neutral);
      color: var(--c-ink);
      width: 100%;
    }
    .community-input:focus {
      outline: 2px solid var(--c-primary);
      outline-offset: 1px;
      background: var(--c-surface);
    }
    .community-terms {
      background: var(--c-neutral);
      border: 1px solid rgba(26, 26, 26, 0.1);
      border-radius: var(--r-sm);
      padding: var(--sp-md);
      max-height: 140px;
      overflow-y: auto;
    }
    .community-terms .body-md {
      color: var(--c-muted);
      margin-bottom: var(--sp-sm);
    }
    .community-terms__list {
      display: flex;
      flex-direction: column;
      gap: var(--sp-xs);
      padding-left: 1.25rem;
      list-style: disc;
    }
    .community-terms__list li {
      font-family: var(--f-body);
      font-size: 0.875rem;
      line-height: 1.5;
      color: var(--c-muted);
    }
    .community-checkbox {
      display: flex;
      align-items: flex-start;
      gap: var(--sp-sm);
      cursor: pointer;
    }
    .community-checkbox input {
      margin-top: 4px;
      width: 16px;
      height: 16px;
      accent-color: var(--c-primary);
      flex-shrink: 0;
    }
    .community-form__error {
      color: var(--c-primary);
    }
    .community-form__error[hidden] {
      display: none;
    }
    .join-modal__actions {
      display: flex;
      gap: var(--sp-sm);
      justify-content: flex-end;
      padding-top: var(--sp-xs);
    }
    #community-form-submit:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }

    /* ═══════════════════════════════
       HEADER
    ═══════════════════════════════ */
    .header {
      background: var(--c-ink);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .header--reveal {
      transform: translateY(-100%);
      transition: transform 0.25s cubic-bezier(0.2, 0, 0, 1);
    }
    .header--reveal.is-visible {
      transform: translateY(0);
    }
    .header__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-block: var(--sp-sm);
      gap: var(--sp-md);
    }
    .wordmark {
      display: flex;
      align-items: center;
      gap: var(--sp-sm);
      color: var(--c-on-ink);
      flex-shrink: 0;
    }
    .wordmark__text {
      font-family: var(--f-display);
      font-size: 0.875rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      text-transform: lowercase;
    }
    .header__nav {
      display: flex;
      align-items: center;
      gap: var(--sp-md);
      margin-left: auto;
    }
    .header__link {
      font-family: var(--f-display);
      font-size: 0.875rem;
      font-weight: 500;
      color: rgba(244, 241, 234, 0.65);
      text-transform: lowercase;
      transition: color 0.15s ease;
    }
    .header__link:hover,
    .header__link[aria-current="page"] {
      color: var(--c-on-ink);
    }
    .header__actions {
      display: flex;
      align-items: center;
      gap: var(--sp-sm);
      flex-shrink: 0;
    }

    /* ═══════════════════════════════
       FOOTER
    ═══════════════════════════════ */
    .footer {
      background: var(--c-ink);
      border-top: 1px solid rgba(244, 241, 234, 0.12);
      padding-block: var(--sp-lg);
    }
    .footer__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--sp-md);
      flex-wrap: wrap;
    }
    .footer__logo {
      display: flex;
      align-items: center;
      gap: var(--sp-sm);
    }
    .footer__links {
      display: flex;
      gap: var(--sp-md);
    }
    .footer__link {
      font-family: var(--f-display);
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: rgba(244, 241, 234, 0.5);
      text-transform: lowercase;
      transition: color 0.15s ease;
    }
    .footer__link:hover {
      color: var(--c-on-ink);
    }

    /* ═══════════════════════════════
       RESOURCE CARDS
    ═══════════════════════════════ */
    .resource-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1px;
      background: var(--c-divider);
      border: 1px solid var(--c-divider);
    }
    .resource-card {
      background: var(--c-surface);
      padding: var(--sp-lg);
      display: flex;
      flex-direction: column;
      gap: var(--sp-sm);
      transition: background 0.15s ease;
    }
    a.resource-card:hover {
      background: rgba(255, 255, 255, 0.92);
    }
    .resource-card__meta {
      display: flex;
      align-items: center;
      gap: var(--sp-sm);
      flex-wrap: wrap;
    }
    .resource-card__tag {
      color: var(--c-primary);
    }
    .resource-card__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: var(--sp-xs);
    }
    .resource-tag {
      font-family: var(--f-mono);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: lowercase;
      color: var(--c-muted);
      background: rgba(26, 26, 26, 0.05);
      padding: 3px 8px;
      border-radius: var(--r-sm);
      border: 1px solid rgba(26, 26, 26, 0.08);
    }
    .resource-filters {
      display: flex;
      flex-wrap: wrap;
      gap: var(--sp-xs);
      margin-bottom: var(--sp-lg);
    }
    .resource-filter {
      font-family: var(--f-display);
      font-size: 0.8125rem;
      font-weight: 500;
      text-transform: lowercase;
      padding: 8px 16px;
      border-radius: var(--r-sm);
      border: 1px solid rgba(26, 26, 26, 0.15);
      background: var(--c-surface);
      color: var(--c-muted);
      cursor: pointer;
      transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    }
    .resource-filter:hover {
      color: var(--c-ink);
      border-color: rgba(26, 26, 26, 0.3);
    }
    .resource-filter.is-active {
      background: var(--c-ink);
      color: var(--c-on-ink);
      border-color: var(--c-ink);
    }
    .resource-card .body-md {
      color: var(--c-muted);
      flex: 1;
    }
    .resource-card__footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--sp-sm);
      margin-top: var(--sp-sm);
      padding-top: var(--sp-sm);
      border-top: 1px solid rgba(26, 26, 26, 0.08);
    }
    .resource-card__read {
      font-family: var(--f-display);
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--c-primary);
      text-transform: lowercase;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: var(--sp-xs);
      font-family: var(--f-display);
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--c-muted);
      text-transform: lowercase;
      margin-bottom: var(--sp-md);
      transition: color 0.15s ease;
    }
    .back-link:hover {
      color: var(--c-ink);
    }

    /* ═══════════════════════════════
       PAGE HERO (resources index)
    ═══════════════════════════════ */
    .page-hero {
      padding-block: clamp(48px, 10vw, 80px);
    }
    .page-hero .eyebrow {
      display: block;
      margin-bottom: var(--sp-sm);
    }
    .page-hero .display-l {
      margin-bottom: var(--sp-md);
    }
    .page-hero__desc {
      color: var(--c-muted);
      max-width: 52ch;
    }

    @media (max-width: 640px) {
      .header__nav { display: none; }
      .footer__inner { flex-direction: column; align-items: flex-start; }
    }
    @media (max-width: 480px) {
      .wordmark__text { display: none; }
    }
  </style>
  <slot name="head" />
</head>
<body>
  <header class:list={['header', Astro.props.headerReveal && 'header--reveal']}>
    <div class="container header__inner">
      <a href="/" class="wordmark" aria-label="ai builders network home">
        <img src="/aibn-logo.svg" alt="" aria-hidden="true" class="logo-img logo-img--sm" />
        <span class="wordmark__text">ai builders network</span>
      </a>
      <nav class="header__nav" aria-label="main">
        <a href="/events" class="header__link" aria-current={Astro.url.pathname.startsWith('/events') ? 'page' : undefined}>events</a>
        <a href="/resources" class="header__link" aria-current={Astro.url.pathname.startsWith('/resources') ? 'page' : undefined}>resources</a>
        <a href="/design-repository" class="header__link" aria-current={Astro.url.pathname.startsWith('/design-repository') ? 'page' : undefined}>design</a>
      </nav>
      <div class="header__actions">
        <a href={joinUrl} class="btn-primary btn--sm">join</a>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__logo">
        <img src="/aibn-logo.svg" alt="" aria-hidden="true" class="logo-img logo-img--sm" />
        <span class="eyebrow eyebrow--on-ink" style="margin-bottom:0">ai builders network · est. 2026</span>
      </div>
      <div class="footer__links">
        <a href="/events" class="footer__link">events</a>
        <a href="/resources" class="footer__link">resources</a>
        <a href="/design-repository" class="footer__link">design</a>
        <a href="/courses" class="footer__link">courses</a>
        <a href="/cohorts" class="footer__link">cohorts</a>
        <a href="/community" class="footer__link">community</a>
        <a href={joinUrl} class="footer__link">join</a>
      </div>
    </div>
  </footer>

  {Astro.props.headerReveal && (
    <script>
      const header = document.querySelector('.header--reveal');
      const hero   = document.querySelector('[data-header-trigger]');
      if (header && hero) {
        const observer = new IntersectionObserver(
          ([entry]) => header.classList.toggle('is-visible', !entry.isIntersecting),
          { threshold: 0 }
        );
        observer.observe(hero);
      }
    </script>
  )}
</body>
</html>
