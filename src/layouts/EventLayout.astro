---
import BaseLayout from './BaseLayout.astro';
import EventSidebar from '../components/EventSidebar.astro';
import { getEventStatusLabel } from '../../lib/event-status';
import type { EventStatus } from '../../lib/event-status';

interface Heading {
  depth: number;
  text: string;
  slug: string;
}

interface Props {
  title: string;
  description: string;
  eventDate: Date;
  eventDateKey: string;
  format: string;
  location: string;
  city: string;
  venue?: string;
  duration?: string;
  price: string;
  hosts: string[];
  ticketUrl: string;
  status: EventStatus;
  headings: Heading[];
}

const {
  title,
  description,
  eventDate,
  eventDateKey,
  format,
  location,
  city,
  venue,
  duration,
  price,
  hosts,
  ticketUrl,
  status,
  headings,
} = Astro.props;

const isLive = status === 'live';
const isPast = status === 'past';
const statusLabel = getEventStatusLabel(status);

const dateLabel = eventDate.toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<BaseLayout title={`${title} · events`} description={description}>
  <article
    class="event-article"
    data-event-root
    data-event-date={eventDateKey}
    data-event-status={status}
  >
    <header class="event-hero section--ink event-hero" aria-labelledby="event-title">
      <div class="container event-hero__inner">
        <a href="/events" class="back-link back-link--on-ink">← all events</a>

        <div class="event-hero__badges">
          <span class="event-hero__live" data-event-live-badge hidden={!isLive} role="status">
            <span class="event-hero__live-dot" aria-hidden="true"></span>
            <span data-event-status-text>{statusLabel}</span>
          </span>
          <span class:list={['event-hero__status', isPast && 'event-hero__status--past']} hidden={isLive}>
            <span data-event-status-text>{statusLabel}</span>
          </span>
          <span class="eyebrow eyebrow--on-ink event-hero__format">{format}</span>
        </div>

        <div class="event-hero__grid">
          <div class="event-hero__main">
            <h1 class="display-l" id="event-title">{title}</h1>
            <p class="body-lg event-hero__desc">{description}</p>

            <div class="event-hero__hosts">
              <span class="eyebrow eyebrow--on-ink">led by</span>
              <ul class="event-hero__host-list">
                {hosts.map((host) => (
                  <li class="event-hero__host">{host}</li>
                ))}
              </ul>
            </div>

            {duration && (
              <p class="body-md event-hero__duration">{duration} · {dateLabel}</p>
            )}
          </div>

          <aside class="event-hero__card" aria-label="event details">
            <div class="event-hero__card-date">
              <span class="event-hero__card-day">
                {eventDate.toLocaleDateString('en-US', { day: 'numeric' })}
              </span>
              <span class="event-hero__card-month">
                {eventDate.toLocaleDateString('en-US', { month: 'short' })}
              </span>
            </div>

            <dl class="event-hero__card-meta">
              <div>
                <dt class="eyebrow">where</dt>
                <dd class="body-md">{location}</dd>
                {venue && <dd class="body-md event-hero__venue">{venue}</dd>}
              </div>
              <div>
                <dt class="eyebrow">price</dt>
                <dd class="heading">{price}</dd>
              </div>
            </dl>

            <a
              href={ticketUrl}
              class="btn-primary event-hero__cta"
              data-event-ticket
              hidden={isPast}
              target="_blank"
              rel="noopener noreferrer"
            >
              {isLive ? 'reserve your seat' : 'get tickets'}
            </a>
            <p class="body-md event-hero__past" data-event-past-note hidden={!isPast}>
              registration closed — this workshop has ended.
            </p>
          </aside>
        </div>
      </div>
    </header>

    <div class="section-divider" role="separator"></div>

    <div class="event-body section--neutral">
      <div class="container event-body__grid">
        <EventSidebar
          headings={headings}
          eventDate={eventDate}
          location={location}
          city={city}
          price={price}
          ticketUrl={ticketUrl}
          status={status}
        />

        <div class="event-main">
          <div class="event-prose">
            <slot />
          </div>
        </div>
      </div>
    </div>
  </article>

  <script>
    function initTocSpy() {
      const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
      const headings = [...links]
        .map((link) => {
          const slug = link.dataset.slug;
          if (!slug) return null;
          const el = document.getElementById(slug);
          return el ? { link, el } : null;
        })
        .filter((item): item is { link: HTMLAnchorElement; el: HTMLElement } => item !== null);

      if (headings.length === 0) return;

      const setActive = (slug: string) => {
        links.forEach((link) => {
          link.classList.toggle('is-active', link.dataset.slug === slug);
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

          if (visible.length > 0) {
            setActive(visible[0].target.id);
          }
        },
        { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
      );

      headings.forEach(({ el }) => observer.observe(el));

      links.forEach((link) => {
        link.addEventListener('click', () => {
          const slug = link.dataset.slug;
          if (slug) setActive(slug);
        });
      });
    }

    initTocSpy();
    document.addEventListener('astro:page-load', initTocSpy);
  </script>

  <script>
    import { initEventStatus } from '../scripts/event-status';

    initEventStatus();
    document.addEventListener('astro:page-load', initEventStatus);
  </script>
</BaseLayout>

<style>
  .event-article {
    --sidebar-width: 240px;
  }

  /* ── HERO ── */
  .event-hero {
    padding-block: clamp(56px, 10vw, 96px);
    border-bottom: 1px solid rgba(244, 241, 234, 0.1);
  }
  .event-hero__inner {
    max-width: var(--max-w);
  }
  .back-link--on-ink {
    color: rgba(244, 241, 234, 0.5);
    margin-bottom: var(--sp-md);
  }
  .back-link--on-ink:hover {
    color: var(--c-on-ink);
  }
  .event-hero__badges {
    display: flex;
    align-items: center;
    gap: var(--sp-sm);
    flex-wrap: wrap;
    margin-bottom: var(--sp-md);
  }
  .event-hero__live {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--f-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-primary);
    background: rgba(199, 62, 34, 0.15);
    padding: 6px 12px;
    border-radius: var(--r-sm);
    border: 1px solid rgba(199, 62, 34, 0.25);
  }
  .event-hero__live[hidden],
  .event-hero__status[hidden] {
    display: none;
  }
  .event-hero__live-dot {
    width: 7px;
    height: 7px;
    border-radius: 1px;
    background: var(--c-primary);
    animation: event-live-pulse 2s ease-in-out infinite;
  }
  @keyframes event-live-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
  @media (prefers-reduced-motion: reduce) {
    .event-hero__live-dot { animation: none; }
  }
  .event-hero__status {
    font-family: var(--f-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-on-ink);
    background: rgba(244, 241, 234, 0.1);
    padding: 6px 12px;
    border-radius: var(--r-sm);
    border: 1px solid rgba(244, 241, 234, 0.15);
  }
  .event-hero__status--past {
    color: rgba(244, 241, 234, 0.5);
  }
  .event-hero__format {
    color: rgba(244, 241, 234, 0.5) !important;
  }
  .event-hero__grid {
    display: grid;
    grid-template-columns: 1fr minmax(260px, 300px);
    gap: clamp(32px, 5vw, 64px);
    align-items: start;
  }
  .event-hero .display-l {
    color: var(--c-on-ink);
    margin-bottom: var(--sp-md);
    max-width: 18ch;
  }
  .event-hero__desc {
    color: rgba(244, 241, 234, 0.65);
    max-width: 52ch;
    margin-bottom: var(--sp-md);
  }
  .event-hero__hosts {
    display: flex;
    flex-direction: column;
    gap: var(--sp-xs);
    padding-top: var(--sp-md);
    border-top: 1px solid rgba(244, 241, 234, 0.1);
    margin-bottom: var(--sp-sm);
  }
  .event-hero__host-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
  }
  .event-hero__host {
    font-family: var(--f-display);
    font-size: 0.9375rem;
    font-weight: 500;
    text-transform: lowercase;
    color: var(--c-on-ink);
    background: rgba(244, 241, 234, 0.08);
    border: 1px solid rgba(244, 241, 234, 0.12);
    padding: 6px 14px;
    border-radius: var(--r-sm);
  }
  .event-hero__duration {
    color: rgba(244, 241, 234, 0.45);
  }

  .event-hero__card {
    background: var(--c-surface);
    color: var(--c-ink);
    border-radius: var(--r-md);
    padding: var(--sp-md);
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
    border: 1px solid rgba(244, 241, 234, 0.08);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.2);
  }
  .event-hero__card-date {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding-bottom: var(--sp-md);
    border-bottom: 1px solid rgba(26, 26, 26, 0.1);
  }
  .event-hero__card-day {
    font-family: var(--f-display);
    font-size: 3rem;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .event-hero__card-month {
    font-family: var(--f-display);
    font-size: 1.125rem;
    font-weight: 500;
    text-transform: lowercase;
  }
  .event-hero__card-meta {
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
  }
  .event-hero__card-meta dt {
    margin-bottom: 4px;
  }
  .event-hero__card-meta dd {
    margin: 0;
    color: var(--c-muted);
  }
  .event-hero__card-meta .heading {
    color: var(--c-ink);
  }
  .event-hero__venue {
    font-size: 0.875rem;
    line-height: 1.5;
    margin-top: 4px !important;
  }
  .event-hero__cta {
    width: 100%;
    text-align: center;
    margin-top: auto;
  }
  .event-hero__past {
    color: var(--c-muted);
    text-align: center;
    padding: var(--sp-sm);
    border: 1px dashed rgba(26, 26, 26, 0.15);
    border-radius: var(--r-sm);
  }

  /* ── BODY GRID ── */
  .event-body {
    padding-block: clamp(40px, 6vw, 72px);
  }
  .event-body__grid {
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: start;
  }
  .event-main {
    min-width: 0;
    max-width: 680px;
  }

  /* ── SIDEBAR ── */
  :global(.event-sidebar) {
    position: sticky;
    top: calc(72px + var(--sp-md));
    display: flex;
    flex-direction: column;
    gap: var(--sp-lg);
  }
  :global(.event-sidebar__ticket) {
    display: none;
    background: var(--c-surface);
    border: 1px solid rgba(26, 26, 26, 0.1);
    border-radius: var(--r-md);
    padding: var(--sp-md);
    flex-direction: column;
    gap: var(--sp-md);
  }
  :global(.event-sidebar__date) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-bottom: var(--sp-md);
    border-bottom: 1px solid rgba(26, 26, 26, 0.08);
  }
  :global(.event-sidebar__date-day) {
    font-family: var(--f-display);
    font-size: 2rem;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  :global(.event-sidebar__date-month) {
    font-family: var(--f-display);
    font-size: 1rem;
    font-weight: 500;
    text-transform: lowercase;
  }
  :global(.event-sidebar__date-meta) {
    margin-top: 4px;
  }
  :global(.event-sidebar__facts) {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
  }
  :global(.event-sidebar__facts dt) {
    margin-bottom: 2px;
  }
  :global(.event-sidebar__facts dd) {
    margin: 0;
    color: var(--c-muted);
  }
  :global(.event-sidebar__facts .heading) {
    color: var(--c-ink);
  }
  :global(.event-sidebar__cta) {
    width: 100%;
    text-align: center;
  }
  :global(.event-sidebar__past-note) {
    color: var(--c-muted);
    text-align: center;
    font-size: 0.875rem;
  }
  :global(.event-sidebar__label) {
    display: block;
    margin-bottom: var(--sp-sm);
  }
  :global(.event-toc__list) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-left: 1px solid rgba(26, 26, 26, 0.12);
    list-style: none;
  }
  :global(.event-toc__item--h3) {
    padding-left: var(--sp-sm);
  }
  :global(.event-toc__link) {
    display: block;
    font-family: var(--f-display);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.4;
    color: var(--c-muted);
    text-transform: lowercase;
    padding: 6px 0 6px var(--sp-sm);
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  :global(.event-toc__link:hover),
  :global(.event-toc__link.is-active) {
    color: var(--c-ink);
    border-left-color: var(--c-primary);
  }

  /* ── PROSE ── */
  .event-prose :global(> p:first-of-type) {
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--c-muted);
    margin-bottom: var(--sp-lg);
    padding-bottom: var(--sp-lg);
    border-bottom: 1px solid rgba(26, 26, 26, 0.1);
  }
  .event-prose :global(h2) {
    font-family: var(--f-display);
    font-size: 1.375rem;
    font-weight: 500;
    line-height: 1.25;
    text-transform: lowercase;
    color: var(--c-ink);
    margin-top: var(--sp-lg);
    margin-bottom: var(--sp-md);
    padding-top: var(--sp-lg);
    border-top: 1px solid rgba(26, 26, 26, 0.1);
    scroll-margin-top: 96px;
  }
  .event-prose :global(h2:first-of-type) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }
  .event-prose :global(h3) {
    font-family: var(--f-display);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.3;
    text-transform: lowercase;
    color: var(--c-ink);
    margin-top: var(--sp-md);
    margin-bottom: var(--sp-sm);
    scroll-margin-top: 96px;
  }
  .event-prose :global(p) {
    margin-bottom: var(--sp-md);
    line-height: 1.75;
    color: var(--c-ink);
  }
  .event-prose :global(ul),
  .event-prose :global(ol) {
    margin-bottom: var(--sp-md);
    padding-left: 1.25rem;
  }
  .event-prose :global(ul) { list-style: disc; }
  .event-prose :global(ol) { list-style: decimal; }
  .event-prose :global(li) {
    margin-bottom: var(--sp-xs);
    line-height: 1.75;
    color: var(--c-muted);
  }
  .event-prose :global(li strong),
  .event-prose :global(p strong) {
    color: var(--c-ink);
    font-weight: 500;
  }
  .event-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-block: var(--sp-md);
    font-size: 0.9375rem;
    border: 1px solid rgba(26, 26, 26, 0.1);
    border-radius: var(--r-md);
    overflow: hidden;
  }
  .event-prose :global(th),
  .event-prose :global(td) {
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid rgba(26, 26, 26, 0.08);
  }
  .event-prose :global(th) {
    font-family: var(--f-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-muted);
    background: rgba(26, 26, 26, 0.03);
  }
  .event-prose :global(td) {
    color: var(--c-ink);
    vertical-align: top;
  }
  .event-prose :global(tr:last-child td) {
    border-bottom: none;
  }
  .event-prose :global(tr:hover td) {
    background: rgba(199, 62, 34, 0.03);
  }

  @media (max-width: 900px) {
    .event-hero__grid {
      grid-template-columns: 1fr;
    }
    .event-hero__card {
      box-shadow: none;
      border: 1px solid rgba(26, 26, 26, 0.12);
    }
    .event-body__grid {
      grid-template-columns: 1fr;
    }
    :global(.event-sidebar) {
      position: static;
      order: -1;
    }
    :global(.event-sidebar__ticket) {
      display: flex;
    }
    .event-hero__card {
      display: none;
    }
  }

  @media (min-width: 901px) {
    :global(.event-toc) {
      display: block;
    }
  }
</style>
