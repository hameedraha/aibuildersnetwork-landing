{
  "colors": {
    "primary": "#1b1938",
    "primary-deep": "#0e0c1f",
    "on-primary": "#ffffff",
    "ink": "#292827",
    "ink-mute": "#73706d",
    "ink-faint": "#9a9794",
    "canvas": "#ffffff",
    "canvas-soft": "#fafaf8",
    "surface-violet-soft": "#c9b4fa",
    "surface-teal-deep": "#0e3030",
    "surface-teal-mid": "#155555",
    "hairline": "#e8e4dd",
    "hairline-dark": "#3f3a52",
    "on-dark-mute": "#bcbac9",
    "on-dark-faint": "#5a5772"
  },
  "primaryColors": {
    "primary": "#1b1938",
    "primary-deep": "#0e0c1f",
    "on-primary": "#ffffff"
  },
  "typography": {
    "display-xxl": {
      "fontFamily": "'Super Sans VF', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "fontSize": "64px",
      "fontWeight": 540,
      "lineHeight": 0.96,
      "letterSpacing": 0
    },
    "display-xl": {
      "fontFamily": "'Super Sans VF', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "fontSize": "48px",
      "fontWeight": 460,
      "lineHeight": 0.96,
      "letterSpacing": "-1.32px"
    },
    "display-lg": {
      "fontFamily": "'Super Sans VF', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "fontSize": "28px",
      "fontWeight": 540,
      "lineHeight": 1.14,
      "letterSpacing": "-0.63px"
    },
    "display-md": {
      "fontFamily": "'Super Sans VF', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "fontSize": "22px",
      "fontWeight": 460,
      "lineHeight": 1.1,
      "letterSpacing": "-0.315px"
    },
    "heading-lg": {
      "fontFamily": "'Super Sans VF', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "fontSize": "20px",
      "fontWeight": 460,
      "lineHeight": 1.2,
      "letterSpacing": "-0.4px"
    },
    "body-lg": {
      "fontFamily": "'Super Sans VF', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "fontSize": "18px",
      "fontWeight": 540,
      "lineHeight": 1.5,
      "letterSpacing": "-0.135px"
    },
    "body-md": {
      "fontFamily": "'Super Sans VF', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "fontSize": "16px",
      "fontWeight": 460,
      "lineHeight": 1.5,
      "letterSpacing": 0
    },
    "body-strong": {
      "fontFamily": "'Super Sans VF', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "fontSize": "18.72px",
      "fontWeight": 700,
      "lineHeight": 1.5,
      "letterSpacing": 0
    },
    "button-md": {
      "fontFamily": "'Super Sans VF', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "fontSize": "16px",
      "fontWeight": 700,
      "lineHeight": 1,
      "letterSpacing": 0
    },
    "button-cap": {
      "fontFamily": "'Super Sans VF', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "fontSize": "14px",
      "fontWeight": 600,
      "lineHeight": 1,
      "letterSpacing": 0
    },
    "caption": {
      "fontFamily": "'Super Sans VF', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "fontSize": "14px",
      "fontWeight": 460,
      "lineHeight": 1.4,
      "letterSpacing": 0
    },
    "micro": {
      "fontFamily": "'Super Sans VF', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "fontSize": "12px",
      "fontWeight": 540,
      "lineHeight": 1.4,
      "letterSpacing": 0
    }
  },
  "components": {
    "button-primary-dark": {
      "backgroundColor": "{colors.primary}",
      "textColor": "{colors.on-primary}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.md}",
      "padding": "12px 20px"
    },
    "button-primary-dark-pressed": {
      "backgroundColor": "{colors.primary-deep}",
      "textColor": "{colors.on-primary}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.md}",
      "padding": "12px 20px"
    },
    "button-on-dark-pill": {
      "backgroundColor": "{colors.surface-violet-soft}",
      "textColor": "{colors.primary}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.full}",
      "padding": "12px 20px"
    },
    "button-secondary-outline": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.md}",
      "padding": "12px 20px"
    },
    "button-on-teal": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.surface-teal-deep}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.md}",
      "padding": "12px 20px"
    },
    "text-input": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.sm}",
      "padding": "10px 12px"
    },
    "card-feature-light": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.lg}",
      "padding": "32px"
    },
    "card-pricing": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.lg}",
      "padding": "32px"
    },
    "card-pricing-featured": {
      "backgroundColor": "{colors.primary}",
      "textColor": "{colors.on-primary}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.lg}",
      "padding": "32px"
    },
    "card-teal-band": {
      "backgroundColor": "{colors.surface-teal-deep}",
      "textColor": "{colors.on-primary}",
      "typography": "{typography.body-lg}",
      "rounded": "{rounded.lg}",
      "padding": "64px"
    },
    "card-feature-row": {
      "backgroundColor": "{colors.canvas-soft}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.md}",
      "padding": "24px"
    },
    "pill-tab-light": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.button-cap}",
      "rounded": "{rounded.full}",
      "padding": "8px 16px"
    },
    "nav-bar-dark": {
      "backgroundColor": "{colors.primary}",
      "textColor": "{colors.on-primary}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.xs}",
      "padding": "16px 24px"
    },
    "nav-bar-light": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.xs}",
      "padding": "16px 24px"
    },
    "link-on-light": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.xs}",
      "padding": "0px"
    },
    "footer-light": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink-mute}",
      "typography": "{typography.caption}",
      "rounded": "{rounded.xs}",
      "padding": "64px 24px"
    }
  },
  "rounded": {
    "xs": "4px",
    "sm": "6px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "full": "9999px"
  },
  "fonts": [
    {
      "name": "'Super Sans VF', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    }
  ],
  "playground": {
    "canvas": "#ffffff",
    "ink": "#292827",
    "surface": "#ffffff",
    "hairline": "#e8e4dd",
    "muted": "#5c5c5c",
    "radiusMd": "8px",
    "buttonPrimary": {
      "backgroundColor": "#1b1938",
      "color": "#ffffff",
      "padding": "12px 20px",
      "borderRadius": "8px",
      "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "700",
      "lineHeight": "1",
      "cursor": "default",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center"
    },
    "buttonSecondary": {
      "backgroundColor": "#ffffff",
      "color": "#292827",
      "padding": "12px 20px",
      "borderRadius": "8px",
      "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "700",
      "lineHeight": "1",
      "cursor": "default",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center"
    },
    "body": {
      "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "460",
      "lineHeight": "1.5"
    },
    "headline": {
      "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
      "fontSize": "22px",
      "fontWeight": "460",
      "lineHeight": "1.1",
      "letterSpacing": "-0.315px"
    },
    "card": {
      "backgroundColor": "#ffffff",
      "color": "#292827",
      "padding": "32px",
      "borderRadius": "12px",
      "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "460",
      "lineHeight": "1.5",
      "border": "1px solid #e8e4dd"
    },
    "input": {
      "backgroundColor": "#ffffff",
      "color": "#292827",
      "padding": "10px 12px",
      "borderRadius": "6px",
      "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "460",
      "lineHeight": "1.5",
      "border": "1px solid #e8e4dd",
      "width": "100%",
      "boxSizing": "border-box"
    },
    "badge": {
      "backgroundColor": "#1b1938",
      "color": "#ffffff",
      "padding": "4px 10px",
      "borderRadius": "8px",
      "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "460",
      "lineHeight": "1.5",
      "display": "inline-block"
    },
    "link": {
      "backgroundColor": "#ffffff",
      "color": "#292827",
      "borderRadius": "4px",
      "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "460",
      "lineHeight": "1.5",
      "textDecoration": "underline",
      "textUnderlineOffset": "2px",
      "cursor": "default"
    },
    "nav": {
      "bar": {
        "backgroundColor": "#1b1938",
        "color": "#ffffff",
        "padding": "16px 24px",
        "borderRadius": "4px",
        "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": "460",
        "lineHeight": "1.5",
        "border": "1px solid #e8e4dd",
        "display": "flex",
        "alignItems": "center",
        "gap": "20px",
        "flexWrap": "wrap"
      },
      "link": {
        "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": "460",
        "lineHeight": "1.5",
        "backgroundColor": "#ffffff",
        "color": "#292827",
        "borderRadius": "4px"
      },
      "linkActive": {
        "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": "460",
        "lineHeight": "1.5",
        "backgroundColor": "#ffffff",
        "color": "#1b1938",
        "borderRadius": "4px"
      }
    },
    "tabActive": {
      "backgroundColor": "#1b1938",
      "color": "#ffffff",
      "padding": "8px 14px",
      "borderRadius": "8px",
      "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "460",
      "lineHeight": "1.5",
      "cursor": "default",
      "display": "inline-block"
    },
    "tabInactive": {
      "backgroundColor": "#ffffff",
      "color": "#292827",
      "padding": "8px 16px",
      "borderRadius": "9999px",
      "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "600",
      "lineHeight": "1",
      "border": "1px solid #e8e4dd",
      "cursor": "default",
      "display": "inline-block"
    },
    "alert": {
      "backgroundColor": "#ffffff",
      "color": "#292827",
      "padding": "12px 16px",
      "borderRadius": "8px",
      "border": "1px solid #e8e4dd",
      "borderLeft": "3px solid #1b1938",
      "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "460",
      "lineHeight": "1.5"
    },
    "code": {
      "backgroundColor": "#292827",
      "color": "#f4f1ea",
      "padding": "14px 16px",
      "borderRadius": "8px",
      "fontFamily": "\"DM Mono\", ui-monospace, monospace",
      "fontSize": "13px",
      "lineHeight": "1.5",
      "display": "block",
      "overflowX": "auto"
    },
    "label": {
      "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "460",
      "lineHeight": "1.4"
    },
    "accordion": {
      "backgroundColor": "#ffffff",
      "color": "#292827",
      "border": "1px solid #e8e4dd",
      "borderRadius": "8px",
      "summaryColor": "#292827",
      "summaryStyle": {
        "fontFamily": "\"Super Sans VF\", system-ui, sans-serif",
        "fontSize": "22px",
        "fontWeight": "460",
        "lineHeight": "1.1",
        "letterSpacing": "-0.315px",
        "color": "#292827",
        "padding": "12px 16px"
      },
      "mutedColor": "#5c5c5c"
    }
  }
}
