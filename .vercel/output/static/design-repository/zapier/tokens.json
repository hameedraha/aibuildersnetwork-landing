  "rounded": {
    "none": "0px",
    "sm": "6px",
    "md": "12px",
    "pill": "9999px",
    "full": "9999px"
  },
  "fonts": [
    {
      "name": "Degular Display, Inter, system-ui, -apple-system, sans-serif",
