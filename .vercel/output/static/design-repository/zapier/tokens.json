      "fontFamily": "Inter, system-ui, sans-serif",
      "fontSize": "18px",
      "fontWeight": 400,
      "lineHeight": "27px"
    },
    "body-md-strong": {
      "fontFamily": "Inter, system-ui, sans-serif",
