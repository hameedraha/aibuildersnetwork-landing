      "fontSize": "15px",
      "fontWeight": "500",
      "lineHeight": "1.2",
      "cursor": "default",
      "display": "inline-block"
    },
    "tabInactive": {
      "backgroundColor": "#f5f1ec",
      "color": "#626260",
      "padding": "8px 16px",
      "borderRadius": "9999px",
      "fontFamily": "\"Saans\", system-ui, sans-serif",
      "fontSize": "15px",
      "fontWeight": "500",
      "lineHeight": "1.2",
      "border": "1px solid #d3cec6",
      "cursor": "default",
      "display": "inline-block"
    },
    "alert": {
      "backgroundColor": "#ffffff",
      "color": "#111111",
      "padding": "48px",
      "borderRadius": "12px",
      "fontFamily": "\"Saans\", system-ui, sans-serif",
      "fontSize": "28px",
      "fontWeight": "500",
      "lineHeight": "1.2",
      "letterSpacing": "-0.5px",
      "border": "1px solid #d3cec6",
      "borderLeft": "3px solid #111111"
