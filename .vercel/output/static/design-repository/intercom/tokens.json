    "code": {
      "backgroundColor": "#111111",
      "color": "#f4f1ea",
      "padding": "14px 16px",
      "borderRadius": "8px",
      "fontFamily": "\"DM Mono\", ui-monospace, monospace",
      "fontSize": "13px",
      "lineHeight": "1.5",
      "display": "block",
      "overflowX": "auto"
    },
    "label": {
      "fontFamily": "\"Saans\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "500",
      "lineHeight": "1.3"
