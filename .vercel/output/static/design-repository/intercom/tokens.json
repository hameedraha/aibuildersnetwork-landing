        "fontWeight": "400",
        "lineHeight": "1.5",
        "border": "1px solid #d3cec6",
        "padding": "12px 16px",
        "display": "flex",
        "alignItems": "center",
        "gap": "20px",
        "flexWrap": "wrap"
