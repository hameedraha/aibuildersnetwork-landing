        "fontFamily": "\"Saans\", system-ui, sans-serif",
        "fontSize": "28px",
        "fontWeight": "500",
        "lineHeight": "1.2",
        "letterSpacing": "-0.5px",
        "color": "#111111",
        "padding": "12px 16px"
      },
      "mutedColor": "#626260"
    }
