  "fonts": [
    {
      "name": "Saans",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    },
    {
      "name": "SaansMono",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    }
  ],
