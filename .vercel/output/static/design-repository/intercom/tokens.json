      "link": {
        "fontFamily": "\"Saans\", system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": "400",
        "lineHeight": "1.5",
        "color": "#111111"
      },
      "linkActive": {
        "fontFamily": "\"Saans\", system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": "400",
        "lineHeight": "1.5",
        "color": "#111111"
      }
