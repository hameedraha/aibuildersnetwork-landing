{
  "colors": {
    "primary": "#ffffff",
    "ink": "#ffffff",
    "body": "#cccccc",
    "body-strong": "#e6e6e6",
    "muted": "#999999",
    "muted-soft": "#666666",
    "hairline": "#262626",
    "hairline-strong": "#3a3a3a",
    "canvas": "#000000",
    "surface-soft": "#0d0d0d",
    "surface-card": "#141414",
    "surface-elevated": "#1f1f1f",
    "on-primary": "#000000",
    "on-dark": "#ffffff",
    "on-photo": "#ffffff",
    "link": "#c3d9f3",
    "warning": "#d4a017",
    "success": "#5fa657"
  },
  "primaryColors": {
    "primary": "#ffffff",
    "on-primary": "#000000"
  },
  "typography": {
    "display-xl": {
      "fontFamily": "Bugatti Display, sans-serif",
      "fontSize": "64px",
      "fontWeight": 400,
      "lineHeight": 1.1,
      "letterSpacing": "4px"
    },
    "display-lg": {
      "fontFamily": "Bugatti Display, sans-serif",
      "fontSize": "48px",
      "fontWeight": 400,
      "lineHeight": 1.15,
      "letterSpacing": "3px"
    },
    "display-md": {
      "fontFamily": "Bugatti Display, sans-serif",
      "fontSize": "32px",
      "fontWeight": 400,
      "lineHeight": 1.2,
      "letterSpacing": "2px"
    },
    "display-sm": {
      "fontFamily": "Bugatti Display, sans-serif",
      "fontSize": "24px",
      "fontWeight": 400,
      "lineHeight": 1.3,
      "letterSpacing": "1.5px"
    },
    "wordmark": {
      "fontFamily": "Bugatti Display, serif",
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": 1,
      "letterSpacing": "6px"
    },
    "title-md": {
      "fontFamily": "Bugatti Display, sans-serif",
      "fontSize": "20px",
      "fontWeight": 400,
      "lineHeight": 1.3,
      "letterSpacing": "1px"
    },
    "title-sm": {
      "fontFamily": "Bugatti Display, sans-serif",
      "fontSize": "16px",
      "fontWeight": 400,
      "lineHeight": 1.3,
      "letterSpacing": "1.5px"
    },
    "caption-uppercase": {
      "fontFamily": "Bugatti Monospace, ui-monospace, monospace",
      "fontSize": "11px",
      "fontWeight": 400,
      "lineHeight": 1.4,
      "letterSpacing": "2px"
    },
    "body-md": {
      "fontFamily": "Bugatti Text Regular, serif",
      "fontSize": "16px",
      "fontWeight": 400,
      "lineHeight": 1.5,
      "letterSpacing": 0
    },
    "body-sm": {
      "fontFamily": "Bugatti Text Regular, serif",
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": 1.5,
      "letterSpacing": 0
    },
    "button": {
      "fontFamily": "Bugatti Monospace, ui-monospace, monospace",
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": 1,
      "letterSpacing": "2.5px"
    },
    "nav-link": {
      "fontFamily": "Bugatti Monospace, ui-monospace, monospace",
      "fontSize": "12px",
      "fontWeight": 400,
      "lineHeight": 1.4,
      "letterSpacing": "2px"
    }
  },
  "components": {
    "button-primary": {
      "backgroundColor": "transparent",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.button}",
      "rounded": "{rounded.pill}",
      "padding": "14px 32px",
      "height": "44px"
    },
    "button-icon": {
      "backgroundColor": "transparent",
      "textColor": "{colors.on-dark}",
      "rounded": "{rounded.full}",
      "size": "40px"
    },
    "text-link": {
      "backgroundColor": "transparent",
      "textColor": "{colors.link}",
      "typography": "{typography.button}"
    },
    "top-nav": {
      "backgroundColor": "transparent",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.nav-link}",
      "height": "56px"
    },
    "wordmark-display": {
      "backgroundColor": "transparent",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.wordmark}"
    },
    "hero-photo-band": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.display-xl}",
      "padding": "96px"
    },
    "caption-overlay": {
      "backgroundColor": "transparent",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.caption-uppercase}"
    },
    "career-callout-card": {
      "backgroundColor": "{colors.surface-card}",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.body-sm}",
      "rounded": "{rounded.none}",
      "padding": "16px",
      "width": "320px"
    },
    "model-photo-card": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.display-md}",
      "rounded": "{rounded.none}"
    },
    "newsroom-article-card": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.title-md}",
      "rounded": "{rounded.none}",
      "padding": "24px"
    },
    "career-listing-row": {
      "backgroundColor": "transparent",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.title-md}",
      "padding": "24px 0"
    },
    "text-input": {
      "backgroundColor": "transparent",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.none}",
      "padding": "12px 0",
      "height": "44px"
    },
    "spec-cell": {
      "backgroundColor": "transparent",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.title-md}",
      "padding": "24px 0"
    },
    "date-pill": {
      "backgroundColor": "transparent",
      "textColor": "{colors.muted}",
      "typography": "{typography.caption-uppercase}"
    },
    "category-tag": {
      "backgroundColor": "transparent",
      "textColor": "{colors.muted}",
      "typography": "{typography.caption-uppercase}"
    },
    "cta-band-photo": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.display-md}",
      "padding": "80px"
    },
    "footer": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.muted}",
      "typography": "{typography.body-sm}",
      "padding": "64px"
    }
  },
  "rounded": {
    "none": "0px",
    "pill": "9999px",
    "full": "9999px"
  },
  "fonts": [
    {
      "name": "Bugatti Display, sans-serif",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    },
    {
      "name": "Bugatti Display, serif",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    },
    {
      "name": "Bugatti Monospace, ui-monospace, monospace",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    },
    {
      "name": "Bugatti Text Regular, serif",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    }
  ],
  "playground": {
    "canvas": "#000000",
    "ink": "#ffffff",
    "surface": "#ffffff",
    "hairline": "#262626",
    "muted": "#999999",
    "radiusMd": "8px",
    "buttonPrimary": {
      "backgroundColor": "transparent",
      "color": "#ffffff",
      "padding": "14px 32px",
      "borderRadius": "9999px",
      "fontFamily": "\"Bugatti Monospace\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "400",
      "lineHeight": "1",
      "letterSpacing": "2.5px",
      "cursor": "default",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center"
    },
    "buttonSecondary": {
      "backgroundColor": "transparent",
      "color": "#ffffff",
      "padding": "12px 20px",
      "borderRadius": "8px",
      "fontFamily": "\"Bugatti Text Regular\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "cursor": "default",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center",
      "border": "1px solid #262626"
    },
    "body": {
      "fontFamily": "\"Bugatti Text Regular\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5"
    },
    "headline": {
      "fontFamily": "\"Bugatti Display\", system-ui, sans-serif",
      "fontSize": "32px",
      "fontWeight": "400",
      "lineHeight": "1.2",
      "letterSpacing": "2px"
    },
    "card": {
      "backgroundColor": "#141414",
      "color": "#ffffff",
      "padding": "16px",
      "fontFamily": "\"Bugatti Text Regular\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "borderRadius": "8px",
      "border": "1px solid #262626"
    },
    "input": {
      "backgroundColor": "transparent",
      "color": "#ffffff",
      "padding": "12px 0",
      "fontFamily": "\"Bugatti Text Regular\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "borderRadius": "8px",
      "border": "1px solid #262626",
      "width": "100%",
      "boxSizing": "border-box"
    },
    "badge": {
      "backgroundColor": "#ffffff",
      "color": "#000000",
      "padding": "4px 10px",
      "borderRadius": "8px",
      "fontFamily": "\"Bugatti Text Regular\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "display": "inline-block"
    },
    "link": {
      "backgroundColor": "transparent",
      "color": "#c3d9f3",
      "fontFamily": "\"Bugatti Monospace\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "400",
      "lineHeight": "1",
      "letterSpacing": "2.5px",
      "textDecoration": "underline",
      "textUnderlineOffset": "2px",
      "cursor": "default"
    },
    "nav": {
      "bar": {
        "backgroundColor": "transparent",
        "color": "#ffffff",
        "fontFamily": "\"Bugatti Monospace\", system-ui, sans-serif",
        "fontSize": "12px",
        "fontWeight": "400",
        "lineHeight": "1.4",
        "letterSpacing": "2px",
        "border": "1px solid #262626",
        "borderRadius": "8px",
        "padding": "12px 16px",
        "display": "flex",
        "alignItems": "center",
        "gap": "20px",
        "flexWrap": "wrap"
      },
      "link": {
        "fontFamily": "\"Bugatti Monospace\", system-ui, sans-serif",
        "fontSize": "14px",
        "fontWeight": "400",
        "lineHeight": "1",
        "backgroundColor": "transparent",
        "color": "#c3d9f3",
        "letterSpacing": "2.5px"
      },
      "linkActive": {
        "fontFamily": "\"Bugatti Monospace\", system-ui, sans-serif",
        "fontSize": "14px",
        "fontWeight": "400",
        "lineHeight": "1",
        "backgroundColor": "transparent",
        "color": "#ffffff",
        "letterSpacing": "2.5px"
      }
    },
    "tabActive": {
      "backgroundColor": "#ffffff",
      "color": "#000000",
      "padding": "8px 14px",
      "borderRadius": "8px",
      "fontFamily": "\"Bugatti Text Regular\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "cursor": "default",
      "display": "inline-block"
    },
    "tabInactive": {
      "backgroundColor": "#ffffff",
      "color": "#ffffff",
      "border": "1px solid #262626",
      "padding": "8px 14px",
      "borderRadius": "8px",
      "fontFamily": "\"Bugatti Text Regular\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "cursor": "default",
      "display": "inline-block"
    },
    "alert": {
      "backgroundColor": "#141414",
      "color": "#ffffff",
      "padding": "16px",
      "fontFamily": "\"Bugatti Text Regular\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "borderRadius": "8px",
      "border": "1px solid #262626",
      "borderLeft": "3px solid #ffffff"
    },
    "code": {
      "backgroundColor": "#ffffff",
      "color": "#f4f1ea",
      "padding": "14px 16px",
      "borderRadius": "8px",
      "fontFamily": "\"DM Mono\", ui-monospace, monospace",
      "fontSize": "13px",
      "lineHeight": "1.5",
      "display": "block",
      "overflowX": "auto"
    },
    "label": {
      "fontFamily": "\"Bugatti Text Regular\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5"
    },
    "accordion": {
      "backgroundColor": "#ffffff",
      "color": "#ffffff",
      "border": "1px solid #262626",
      "borderRadius": "8px",
      "summaryColor": "#ffffff",
      "summaryStyle": {
        "fontFamily": "\"Bugatti Display\", system-ui, sans-serif",
        "fontSize": "32px",
        "fontWeight": "400",
        "lineHeight": "1.2",
        "letterSpacing": "2px",
        "color": "#ffffff",
        "padding": "12px 16px"
      },
      "mutedColor": "#999999"
    }
  }
}
