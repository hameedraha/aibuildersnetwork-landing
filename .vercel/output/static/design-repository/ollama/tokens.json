{
  "colors": {
    "primary": "#000000",
    "on-primary": "#ffffff",
    "ink": "#000000",
    "ink-deep": "#090909",
    "charcoal": "#525252",
    "body": "#737373",
    "mute": "#a3a3a3",
    "canvas": "#ffffff",
    "surface-soft": "#fafafa",
    "surface-card": "#ffffff",
    "hairline": "#e5e5e5",
    "hairline-strong": "#d4d4d4",
    "on-dark": "#ffffff",
    "on-dark-mute": "rgba(255,255,255,0.7)",
    "surface-dark": "#171717",
    "focus-ring": "rgba(59,130,246,0.5)",
    "link": "#000000",
    "link-mute": "#737373",
    "terminal-red": "#ff5f56",
    "terminal-yellow": "#ffbd2e",
    "terminal-green": "#27c93f"
  },
  "primaryColors": {
    "primary": "#000000",
    "on-primary": "#ffffff"
  },
  "typography": {
    "display-xl": {
      "fontFamily": "SF Pro Rounded",
      "fontSize": "36px",
      "fontWeight": 500,
      "lineHeight": 1.11,
      "letterSpacing": 0
    },
    "display-lg": {
      "fontFamily": "SF Pro Rounded",
      "fontSize": "30px",
      "fontWeight": 500,
      "lineHeight": 1.2,
      "letterSpacing": 0
    },
    "heading-lg": {
      "fontFamily": "SF Pro Rounded",
      "fontSize": "24px",
      "fontWeight": 600,
      "lineHeight": 1.33,
      "letterSpacing": 0
    },
    "heading-md": {
      "fontFamily": "ui-sans-serif",
      "fontSize": "20px",
      "fontWeight": 500,
      "lineHeight": 1.4,
      "letterSpacing": 0
    },
    "heading-sm": {
      "fontFamily": "ui-sans-serif",
      "fontSize": "18px",
      "fontWeight": 500,
      "lineHeight": 1.56,
      "letterSpacing": 0
    },
    "body-md": {
      "fontFamily": "ui-sans-serif",
      "fontSize": "16px",
      "fontWeight": 400,
      "lineHeight": 1.5,
      "letterSpacing": 0
    },
    "body-strong": {
      "fontFamily": "ui-sans-serif",
      "fontSize": "16px",
      "fontWeight": 500,
      "lineHeight": 1.5,
      "letterSpacing": 0
    },
    "body-sm": {
      "fontFamily": "ui-sans-serif",
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": 1.43,
      "letterSpacing": 0
    },
    "body-sm-strong": {
      "fontFamily": "ui-sans-serif",
      "fontSize": "14px",
      "fontWeight": 500,
      "lineHeight": 1.43,
      "letterSpacing": 0
    },
    "caption-sm": {
      "fontFamily": "ui-sans-serif",
      "fontSize": "12px",
      "fontWeight": 400,
      "lineHeight": 1.33,
      "letterSpacing": 0
    },
    "code-md": {
      "fontFamily": "ui-monospace",
      "fontSize": "16px",
      "fontWeight": 400,
      "lineHeight": 1.5,
      "letterSpacing": 0
    },
    "code-sm": {
      "fontFamily": "ui-monospace",
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": 1.43,
      "letterSpacing": 0
    },
    "button-md": {
      "fontFamily": "ui-sans-serif",
      "fontSize": "14px",
      "fontWeight": 500,
      "lineHeight": 1,
      "letterSpacing": 0
    }
  },
  "components": {
    "button-primary": {
      "backgroundColor": "{colors.primary}",
      "textColor": "{colors.on-primary}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.full}",
      "padding": "8px 20px",
      "height": "36px"
    },
    "button-primary-active": {
      "backgroundColor": "{colors.ink-deep}",
      "textColor": "{colors.on-primary}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.full}"
    },
    "button-secondary": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.full}",
      "padding": "8px 20px",
      "height": "36px"
    },
    "button-pill-on-dark": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.button-md}",
      "rounded": "{rounded.full}",
      "padding": "8px 20px"
    },
    "button-disabled": {
      "backgroundColor": "{colors.surface-soft}",
      "textColor": "{colors.mute}",
      "rounded": "{rounded.full}"
    },
    "search-pill": {
      "backgroundColor": "{colors.surface-soft}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-sm}",
      "rounded": "{rounded.full}",
      "padding": "8px 16px",
      "height": "36px"
    },
    "search-pill-focused": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "rounded": "{rounded.full}"
    },
    "text-input": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.full}",
      "padding": "8px 16px",
      "height": "40px"
    },
    "text-input-focused": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "rounded": "{rounded.full}"
    },
    "install-snippet": {
      "backgroundColor": "{colors.surface-soft}",
      "textColor": "{colors.ink}",
      "typography": "{typography.code-md}",
      "rounded": "{rounded.full}",
      "padding": "12px 20px",
      "height": "48px"
    },
    "command-tag": {
      "backgroundColor": "{colors.surface-soft}",
      "textColor": "{colors.ink}",
      "typography": "{typography.code-sm}",
      "rounded": "{rounded.full}",
      "padding": "6px 12px"
    },
    "terminal-card": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.code-sm}",
      "rounded": "{rounded.lg}",
      "padding": "16px"
    },
    "terminal-traffic-lights": {
      "rounded": "{rounded.full}",
      "size": "12px"
    },
    "pricing-card": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.lg}",
      "padding": "32px"
    },
    "pricing-card-dark": {
      "backgroundColor": "{colors.surface-dark}",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.lg}",
      "padding": "32px"
    },
    "feature-bullet": {
      "textColor": "{colors.charcoal}",
      "typography": "{typography.body-sm}"
    },
    "faq-row": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-md}",
      "rounded": "{rounded.none}",
      "padding": "16px 0px"
    },
    "link-inline": {
      "textColor": "{colors.ink}",
      "typography": "{typography.body-md}"
    },
    "link-mute": {
      "textColor": "{colors.body}",
      "typography": "{typography.body-sm}"
    },
    "primary-nav": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-sm-strong}",
      "rounded": "{rounded.none}",
      "height": "56px"
    },
    "footer-section": {
      "backgroundColor": "{colors.canvas}",
      "textColor": "{colors.body}",
      "typography": "{typography.caption-sm}",
      "rounded": "{rounded.none}",
      "padding": "32px 24px"
    },
    "cta-strip-dark": {
      "backgroundColor": "{colors.surface-dark}",
      "textColor": "{colors.on-dark}",
      "typography": "{typography.heading-lg}",
      "rounded": "{rounded.lg}",
      "padding": "24px 32px"
    }
  },
  "rounded": {
    "none": "0px",
    "sm": "6px",
    "md": "8px",
    "lg": "12px",
    "full": "9999px"
  },
  "fonts": [
    {
      "name": "SF Pro Rounded",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    },
    {
      "name": "ui-sans-serif",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    },
    {
      "name": "ui-monospace",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    }
  ],
  "playground": {
    "canvas": "#ffffff",
    "ink": "#000000",
    "surface": "#ffffff",
    "hairline": "#e5e5e5",
    "muted": "#737373",
    "radiusMd": "8px",
    "buttonPrimary": {
      "backgroundColor": "#000000",
      "color": "#ffffff",
      "padding": "8px 20px",
      "borderRadius": "9999px",
      "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "500",
      "lineHeight": "1",
      "cursor": "default",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center"
    },
    "buttonSecondary": {
      "backgroundColor": "#ffffff",
      "color": "#000000",
      "padding": "8px 20px",
      "borderRadius": "9999px",
      "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
      "fontSize": "14px",
      "fontWeight": "500",
      "lineHeight": "1",
      "cursor": "default",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center"
    },
    "body": {
      "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5"
    },
    "headline": {},
    "card": {
      "backgroundColor": "#ffffff",
      "color": "#000000",
      "padding": "32px",
      "borderRadius": "12px",
      "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "border": "1px solid #e5e5e5"
    },
    "input": {
      "backgroundColor": "#ffffff",
      "color": "#000000",
      "padding": "8px 16px",
      "borderRadius": "9999px",
      "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "border": "1px solid #e5e5e5",
      "width": "100%",
      "boxSizing": "border-box"
    },
    "badge": {
      "backgroundColor": "#000000",
      "color": "#ffffff",
      "padding": "4px 10px",
      "borderRadius": "8px",
      "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "display": "inline-block"
    },
    "link": {
      "color": "#000000",
      "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "textDecoration": "underline",
      "textUnderlineOffset": "2px",
      "cursor": "default"
    },
    "nav": {
      "bar": {
        "backgroundColor": "#ffffff",
        "color": "#000000",
        "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
        "fontSize": "14px",
        "fontWeight": "500",
        "lineHeight": "1.43",
        "border": "1px solid #e5e5e5",
        "borderRadius": "8px",
        "padding": "12px 16px",
        "display": "flex",
        "alignItems": "center",
        "gap": "20px",
        "flexWrap": "wrap"
      },
      "link": {
        "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": "400",
        "lineHeight": "1.5",
        "color": "#000000"
      },
      "linkActive": {
        "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": "400",
        "lineHeight": "1.5",
        "color": "#000000"
      }
    },
    "tabActive": {
      "backgroundColor": "#000000",
      "color": "#ffffff",
      "padding": "8px 14px",
      "borderRadius": "8px",
      "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "cursor": "default",
      "display": "inline-block"
    },
    "tabInactive": {
      "backgroundColor": "#ffffff",
      "color": "#000000",
      "border": "1px solid #e5e5e5",
      "padding": "8px 14px",
      "borderRadius": "8px",
      "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5",
      "cursor": "default",
      "display": "inline-block"
    },
    "alert": {
      "backgroundColor": "#ffffff",
      "color": "#000000",
      "padding": "12px 16px",
      "borderRadius": "8px",
      "border": "1px solid #e5e5e5",
      "borderLeft": "3px solid #000000",
      "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5"
    },
    "code": {
      "backgroundColor": "#000000",
      "color": "#f4f1ea",
      "padding": "14px 16px",
      "borderRadius": "8px",
      "fontFamily": "\"DM Mono\", ui-monospace, monospace",
      "fontSize": "13px",
      "lineHeight": "1.5",
      "display": "block",
      "overflowX": "auto"
    },
    "label": {
      "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "400",
      "lineHeight": "1.5"
    },
    "accordion": {
      "backgroundColor": "#ffffff",
      "color": "#000000",
      "border": "1px solid #e5e5e5",
      "borderRadius": "8px",
      "summaryColor": "#000000",
      "summaryStyle": {
        "fontFamily": "\"ui-sans-serif\", system-ui, sans-serif",
        "fontSize": "16px",
        "fontWeight": "400",
        "lineHeight": "1.5",
        "color": "#000000",
        "padding": "12px 16px"
      },
      "mutedColor": "#737373"
    }
  }
}
