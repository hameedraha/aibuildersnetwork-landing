    "color-block-section-navy": {
      "backgroundColor": "{colors.block-navy}",
      "textColor": "{colors.inverse-ink}",
      "typography": "{typography.subhead}",
      "rounded": "{rounded.lg}",
      "padding": "48px"
    },
    "promo-banner-lilac": {
      "backgroundColor": "{colors.block-lilac}",
      "textColor": "{colors.ink}",
      "typography": "{typography.body-sm}",
      "rounded": "{rounded.md}",
      "padding": "16px 24px"
