  "rounded": {
    "xs": "2px",
    "sm": "6px",
    "md": "8px",
    "lg": "24px",
    "xl": "32px",
    "pill": "50px",
    "full": "9999px"
  },
  "fonts": [
    {
      "name": "figmaSans",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    },
    {
      "name": "figmaMono",
      "source": "custom",
      "note": "proprietary or not available on google fonts"
    }
  ],
