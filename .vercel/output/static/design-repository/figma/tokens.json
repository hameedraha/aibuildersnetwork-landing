      "link": {
        "fontFamily": "\"figmaSans\", system-ui, sans-serif",
        "fontSize": "18px",
        "fontWeight": "320",
        "lineHeight": "1.45",
        "letterSpacing": "-0.26px",
        "color": "#000000"
      },
      "linkActive": {
        "fontFamily": "\"figmaSans\", system-ui, sans-serif",
        "fontSize": "18px",
        "fontWeight": "320",
        "lineHeight": "1.45",
        "letterSpacing": "-0.26px",
        "color": "#000000"
