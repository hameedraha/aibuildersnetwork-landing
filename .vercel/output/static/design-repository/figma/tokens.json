    "label": {
      "fontFamily": "\"figmaMono\", system-ui, sans-serif",
      "fontSize": "18px",
      "fontWeight": "400",
      "lineHeight": "1.3",
      "letterSpacing": "0.54px"
    },
    "accordion": {
      "backgroundColor": "#000000",
      "color": "#000000",
      "border": "1px solid #e6e6e6",
      "borderRadius": "8px",
      "summaryColor": "#000000",
      "summaryStyle": {
        "fontFamily": "\"figmaSans\", system-ui, sans-serif",
        "fontSize": "26px",
        "fontWeight": "540",
        "lineHeight": "1.35",
        "letterSpacing": "-0.26px",
        "color": "#000000",
        "padding": "12px 16px"
      },
      "mutedColor": "#5c5c5c"
    }
