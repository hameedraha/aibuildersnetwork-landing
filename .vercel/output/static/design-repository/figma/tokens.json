      "fontFamily": "\"figmaSans\", system-ui, sans-serif",
      "fontSize": "20px",
      "fontWeight": "480",
      "lineHeight": "1.4",
      "letterSpacing": "-0.10px",
      "cursor": "default",
      "display": "inline-block"
    },
    "tabInactive": {
      "backgroundColor": "#ffffff",
      "color": "#000000",
      "padding": "8px 18px",
      "borderRadius": "50px",
      "fontFamily": "\"figmaSans\", system-ui, sans-serif",
      "fontSize": "20px",
      "fontWeight": "480",
      "lineHeight": "1.4",
      "letterSpacing": "-0.10px",
      "border": "1px solid #e6e6e6",
      "cursor": "default",
      "display": "inline-block"
    },
    "alert": {
      "backgroundColor": "#c5b0f4",
      "color": "#000000",
      "padding": "16px 24px",
      "borderRadius": "8px",
      "fontFamily": "\"figmaSans\", system-ui, sans-serif",
      "fontSize": "16px",
      "fontWeight": "330",
      "lineHeight": "1.45",
      "letterSpacing": "-0.14px",
      "border": "1px solid #e6e6e6",
      "borderLeft": "3px solid #000000"
