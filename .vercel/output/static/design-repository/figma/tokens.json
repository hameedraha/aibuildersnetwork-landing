      "backgroundColor": "#000000",
      "color": "#ffffff",
      "padding": "10px 20px",
      "borderRadius": "50px",
      "fontFamily": "\"figmaSans\", system-ui, sans-serif",
      "fontSize": "20px",
      "fontWeight": "480",
      "lineHeight": "1.4",
