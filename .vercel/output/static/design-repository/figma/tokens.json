      "fontFamily": "\"figmaSans\", system-ui, sans-serif",
      "fontSize": "20px",
      "fontWeight": "480",
      "lineHeight": "1.4",
      "letterSpacing": "-0.10px",
      "cursor": "default",
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "center"
